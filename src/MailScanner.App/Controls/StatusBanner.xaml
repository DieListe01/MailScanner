<UserControl x:Class="MailScanner.App.Controls.StatusBanner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MailScanner.App.Controls"
             mc:Ignorable="d"
             d:DesignHeight="40" d:DesignWidth="800">
    <Grid>
        <Border x:Name="BannerBorder"
                CornerRadius="6"
                Padding="12,8"
                Margin="0"
                Background="{Binding BackgroundBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Path x:Name="Icon"
                      Width="16" Height="16"
                      Margin="0,0,8,0"
                      VerticalAlignment="Center"
                      Fill="{Binding IconBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      Data="{Binding IconData, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding Message, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontSize="12"
                           Foreground="{Binding TextBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>