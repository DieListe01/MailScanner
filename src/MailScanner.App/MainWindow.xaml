<Window x:Class="MailScanner.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MailScanner"
        Height="700"
        Width="1000"
        MinHeight="650"
        MinWidth="900"
        Background="#F8F9FA">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TextBrush" Color="#212529" />
        <SolidColorBrush x:Key="MutedBrush" Color="#6C757D" />
        <SolidColorBrush x:Key="StrokeBrush" Color="#DEE2E6" />
        <SolidColorBrush x:Key="ShellBrush" Color="#F8F9FA" />
        <SolidColorBrush x:Key="HeroBrush" Color="#495057" />
        <SolidColorBrush x:Key="AccentBrush" Color="#007BFF" />
        <DropShadowEffect x:Key="PanelShadow" BlurRadius="8" ShadowDepth="2" Color="#000000" Opacity="0.1" />
        <DropShadowEffect x:Key="HeroShadow" BlurRadius="12" ShadowDepth="3" Color="#000000" Opacity="0.15" />
        <DropShadowEffect x:Key="ButtonShadow" BlurRadius="6" ShadowDepth="1" Color="#000000" Opacity="0.1" />

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="Effect" Value="{StaticResource PanelShadow}" />
        </Style>

        <Style x:Key="HeroChipStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="#E9ECEF" />
            <Setter Property="BorderBrush" Value="#CED4DA" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="InfoChipStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="#F8F9FA" />
            <Setter Property="BorderBrush" Value="#E9ECEF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>


    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="20" CornerRadius="8" Background="{StaticResource HeroBrush}" Effect="{StaticResource HeroShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="280" />
                </Grid.ColumnDefinitions>

                <Grid Margin="0,0,28,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left"
                                       Text="MailScanner"
                                       FontFamily="Segoe UI"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="#FFFFFF" />
                            <Border DockPanel.Dock="Left"
                                    Margin="8,6,0,0"
                                    Padding="6,3"
                                    CornerRadius="4"
                                    Background="{StaticResource AccentBrush}"
                                    BorderThickness="1">
                                <TextBlock Text="{Binding CurrentVersionSummary}"
                                           Foreground="#FFFFFF"
                                           FontWeight="Normal"
                                           FontSize="12" />
                            </Border>
                        </DockPanel>

                        <TextBlock Margin="0,8,0,0"
                                   MaxWidth="500"
                                   FontSize="14"
                                   LineHeight="20"
                                   TextWrapping="Wrap"
                                   Foreground="#E9ECEF"
                                   Text="Dokumente aus privaten Postfächern strukturiert sammeln, priorisieren, prüfen und sicher ins lokale DMS übernehmen." />
                            </StackPanel>

                        <Border Grid.Row="1"
                                Margin="0,12,0,0"
                                Padding="12,8"
                                CornerRadius="6"
                                Background="#343A40"
                                BorderBrush="#495057"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Release-Status"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#E9ECEF" />
                                <Border Margin="0,6,0,0"
                                        Padding="6,2"
                                        HorizontalAlignment="Left"
                                        CornerRadius="4"
                                        Background="#6C757D"
                                        BorderThickness="1">
                                    <TextBlock Text="{Binding LatestVersionSummary}"
                                               Foreground="#FFFFFF"
                                               FontWeight="Normal"
                                               FontSize="10" />
                                </Border>
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding UpdateStatusSummary}"
                                           Foreground="#DEE2E6"
                                           FontSize="11"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <WrapPanel Grid.Row="2" Margin="0,12,0,0">
                            <Border Style="{StaticResource HeroChipStyle}">
                                <TextBlock Text="Vorschau vor dem Download" Foreground="#495057" FontSize="11" />
                            </Border>
                            <Border Style="{StaticResource HeroChipStyle}">
                                <TextBlock Text="SQLite + Dateisystem" Foreground="#495057" FontSize="11" />
                            </Border>
                            <Border Style="{StaticResource HeroChipStyle}">
                                <TextBlock Text="Kompletter Verlauf scanbar" Foreground="#495057" FontSize="11" />
                            </Border>
                        </WrapPanel>
                    </Grid>

                    <Border Grid.Column="1"
                            Padding="16"
                            CornerRadius="8"
                            Background="#FFFFFF"
                            BorderBrush="#DEE2E6"
                            BorderThickness="1"
                            Effect="{StaticResource PanelShadow}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Aktionen"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#212529" />
                            <TextBlock Grid.Row="1"
                                       Margin="0,4,0,0"
                                       Text="Die wichtigsten Aktionen kompakt in einem Bereich."
                                       Foreground="#6C757D"
                                       FontSize="11"
                                       TextWrapping="Wrap" />

                            <Border Grid.Row="2"
                                    Margin="0,12,0,0"
                                    Padding="12"
                                    CornerRadius="6"
                                    Background="#F8F9FA"
                                    BorderBrush="#DEE2E6"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="6" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="6" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Button x:Name="SettingsButton" Grid.Row="0" Grid.Column="0" Style="{StaticResource PrimaryActionButton}" Click="OnOpenSettingsClicked" Content="Konten" />
                                    <Button x:Name="TestConnectionButton" Grid.Row="0" Grid.Column="2" Style="{StaticResource SecondaryActionButton}" Click="OnTestConnectionsClicked" Content="Verbindung" />
                                    <Button x:Name="RefreshButton" Grid.Row="2" Grid.Column="0" Style="{StaticResource SecondaryActionButton}" Click="OnRefreshClicked" Content="Postfächer prüfen" />
                                    <Button x:Name="DownloadButton" Grid.Row="2" Grid.Column="2" Style="{StaticResource PrimaryActionButton}" Click="OnDownloadSelectionClicked" Content="Auswahl speichern" />
                                    <Button Grid.Row="4" Grid.ColumnSpan="3" Style="{StaticResource PrimaryActionButton}" Click="OnOpenLatestReleaseClicked" Content="{Binding LatestReleaseButtonText}" Visibility="{Binding LatestReleaseVisibility}" />
                                </Grid>
                            </Border>

                            <Grid Grid.Row="3" Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Margin="0,0,4,0"
                                        Padding="8,4"
                                        CornerRadius="4"
                                        Background="#E9ECEF"
                                        BorderBrush="#CED4DA"
                                        BorderThickness="1">
                                    <TextBlock Text="Vollscan" Foreground="#495057" FontWeight="Normal" FontSize="10" />
                                </Border>
                                <Border Grid.Column="1"
                                        Margin="4,0,0,0"
                                        Padding="8,4"
                                        CornerRadius="4"
                                        Background="#E9ECEF"
                                        BorderBrush="#CED4DA"
                                        BorderThickness="1">
                                    <TextBlock Text="Live-Updatecheck" Foreground="#495057" FontWeight="Normal" FontSize="10" />
                                </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,20,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Margin="0,0,16,0" Style="{StaticResource MetricCardStyle}">
                    <Grid>
                        <Border Height="6" VerticalAlignment="Top" HorizontalAlignment="Stretch" Background="#7FA6D5" CornerRadius="22,22,6,6" />
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Text="Konten" FontSize="12" Foreground="{StaticResource MutedBrush}" />
                            <TextBlock Text="{Binding AccountCountSummary}" Margin="0,6,0,0" FontFamily="Bahnschrift" FontSize="22" Foreground="{StaticResource TextBrush}" />
                            <TextBlock Margin="0,3,0,0" Text="IMAP-Zugaenge zentral verwalten" FontSize="11" Foreground="{StaticResource MutedBrush}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Margin="0,0,16,0" Style="{StaticResource MetricCardStyle}">
                    <Grid>
                        <Border Height="6" VerticalAlignment="Top" HorizontalAlignment="Stretch" Background="#92B5DB" CornerRadius="22,22,6,6" />
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Text="Anhang-Mails" FontSize="12" Foreground="{StaticResource MutedBrush}" />
                            <TextBlock Text="{Binding AttachmentMailSummary}" Margin="0,6,0,0" FontFamily="Bahnschrift" FontSize="22" Foreground="{StaticResource TextBrush}" />
                            <TextBlock Margin="0,3,0,0" Text="Alle Mails mit Anhaengen im Scan" FontSize="11" Foreground="{StaticResource MutedBrush}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Margin="0,0,16,0" Style="{StaticResource MetricCardStyle}">
                    <Grid>
                        <Border Height="6" VerticalAlignment="Top" HorizontalAlignment="Stretch" Background="#7DB5D6" CornerRadius="22,22,6,6" />
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Text="PDF-Kandidaten" FontSize="12" Foreground="{StaticResource MutedBrush}" />
                            <TextBlock Text="{Binding PdfCandidateSummary}" Margin="0,6,0,0" FontFamily="Bahnschrift" FontSize="22" Foreground="{StaticResource TextBrush}" />
                            <TextBlock Margin="0,3,0,0" Text="Nur PDF-Anhaenge landen im Review" FontSize="11" Foreground="{StaticResource MutedBrush}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource MetricCardStyle}" Background="{StaticResource InvoiceBrush}">
                    <Grid>
                        <Border Height="6" VerticalAlignment="Top" HorizontalAlignment="Stretch" Background="#AFCBEB" CornerRadius="22,22,6,6" Opacity="0.65" />
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Text="Rechnungs-Treffer" FontSize="12" Foreground="#D9E8FA" />
                            <TextBlock Text="{Binding InvoiceMatchSummary}" Margin="0,6,0,0" FontFamily="Bahnschrift" FontSize="22" Foreground="#FFFFFF" />
                            <TextBlock Margin="0,3,0,0" Text="Keywords wie invoice, rechnung, beleg" FontSize="11" Foreground="#E8F2FE" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Padding="26" CornerRadius="32" Background="{StaticResource PanelBrush}" Effect="{StaticResource PanelShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="330" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Gefundene Dokumente vor dem Download"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}" />
                            <TextBlock Margin="0,8,0,0"
                                        Text="{Binding StatusMessage}"
                                        Foreground="#4A6785"
                                        TextWrapping="Wrap" />

                            <WrapPanel Margin="0,14,0,0">
                                <Border Style="{StaticResource InfoChipStyle}">
                                    <TextBlock Text="{Binding LookbackScopeSummary}" Foreground="#3D648B" />
                                </Border>
                                <Border Style="{StaticResource InfoChipStyle}">
                                    <TextBlock Text="{Binding OldestMailSummary}" Foreground="#3D648B" />
                                </Border>
                                <Border Style="{StaticResource InfoChipStyle}">
                                    <TextBlock Text="{Binding ExcludedFoldersSummary}" Foreground="#3D648B" />
                                </Border>
                            </WrapPanel>

                            <Border Margin="0,12,0,0"
                                    Padding="16,14"
                                    CornerRadius="18"
                                    Background="#F4F8FE"
                                    BorderBrush="#D7E3F1"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Verbindung und Diagnose"
                                               FontWeight="SemiBold"
                                               Foreground="#35597E" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="Letzte Rueckmeldung aus dem Kontentest"
                                               Foreground="#7A91AA"
                                               FontSize="12" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="{Binding LastConnectionTestSummary}"
                                               Foreground="{StaticResource MutedBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,14,0,0"
                                    Padding="16"
                                    Background="#EAF3FF"
                                    CornerRadius="18"
                                    BorderBrush="#D2E2F5"
                                    BorderThickness="1"
                                    Visibility="{Binding BusyVisibility}">
                                <StackPanel>
                                    <TextBlock Text="{Binding BusyMessage}"
                                               FontWeight="SemiBold"
                                               Foreground="#224F7A" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding ScanProgressSummary}"
                                               Foreground="#4B7195"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding CurrentScanTarget}"
                                               Foreground="#4B7195"
                                               TextWrapping="Wrap" />
                                    <ProgressBar Margin="0,12,0,0"
                                                 Height="10"
                                                 IsIndeterminate="True"
                                                 Foreground="#4A82BD"
                                                 Background="#C8DCF3" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Border Grid.Column="1"
                                HorizontalAlignment="Right"
                                Padding="18"
                                CornerRadius="22"
                                Background="#F3F8FF"
                                BorderBrush="{StaticResource StrokeBrush}"
                                BorderThickness="1">
                            <StackPanel Width="260">
                                <Border Padding="9,4"
                                        HorizontalAlignment="Left"
                                        CornerRadius="999"
                                        Background="#E7F0FC"
                                        BorderBrush="#D2E1F2"
                                        BorderThickness="1">
                                    <TextBlock Text="Suche und Filter"
                                               Foreground="#3A5F84"
                                               FontWeight="SemiBold"
                                               FontSize="12" />
                                </Border>
                                <TextBlock Margin="0,10,0,0"
                                           Text="Filtert Konto, Betreff, Anhang oder Message-ID in der lokalen Review-Liste."
                                           Foreground="#7A90AA"
                                           FontSize="12"
                                           TextWrapping="Wrap" />
                                <TextBox x:Name="SearchBox"
                                          Margin="0,14,0,0"
                                          Height="40"
                                          Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                                <Border Margin="0,12,0,0"
                                        Padding="12,10"
                                        CornerRadius="14"
                                        Background="#FFFFFF"
                                        BorderBrush="#DBE6F3"
                                        BorderThickness="1">
                                    <TextBlock Text="Tipp: Suche nach Absender, Dateiname, Rechnungsbegriffen oder Message-ID."
                                               Foreground="#6E86A0"
                                               FontSize="11"
                                               TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="1"
                            CornerRadius="24"
                            Background="#F6FAFF"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            Padding="10">
                        <DataGrid Grid.Row="1"
                                  x:Name="CandidatesGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  GridLinesVisibility="None"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  SelectionMode="Extended"
                                  SelectionUnit="FullRow"
                                  AlternatingRowBackground="#F2F7FE"
                                  Background="#F8FBFF"
                                  BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ItemsSource="{Binding Candidates}">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#E3EEFB" />
                                    <Setter Property="Foreground" Value="#17304B" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Padding" Value="12,11" />
                                    <Setter Property="BorderBrush" Value="#D5E3F2" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                </Style>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding" Value="9,8" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                </Style>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="#F8FBFF" />
                                    <Setter Property="Foreground" Value="#17304B" />
                                    <Setter Property="Height" Value="44" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#EEF5FF" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#DDECFB" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="1.0*" MinWidth="110" Header="Konto" Binding="{Binding AccountName}" />
                                <DataGridTextColumn Width="1.45*" MinWidth="180" Header="Absender" Binding="{Binding Sender}" />
                                <DataGridTextColumn Width="2.2*" MinWidth="250" Header="Betreff" Binding="{Binding Subject}" />
                                <DataGridTextColumn Width="1.0*" MinWidth="120" Header="Empfangen" Binding="{Binding ReceivedAtDisplay}" />
                                <DataGridTextColumn Width="1.75*" MinWidth="210" Header="Anhang" Binding="{Binding AttachmentName}" />
                                <DataGridTextColumn Width="0.75*" MinWidth="84" Header="Groesse" Binding="{Binding AttachmentSizeDisplay}" />
                                <DataGridTemplateColumn Width="0.7*" MinWidth="90" Header="Score">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,5" CornerRadius="13" Background="{Binding PriorityBadgeBackground}">
                                                <TextBlock HorizontalAlignment="Center" Text="{Binding PriorityScore}" Foreground="{Binding PriorityBadgeForeground}" FontWeight="SemiBold" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="0.92*" MinWidth="110" Header="Prioritaet">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,5" CornerRadius="13" Background="{Binding PriorityBadgeBackground}">
                                                <TextBlock HorizontalAlignment="Center" Text="{Binding PriorityLabel}" Foreground="{Binding PriorityBadgeForeground}" FontWeight="SemiBold" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="1.15*" MinWidth="150" Header="Treffergrund" Binding="{Binding MatchReasonCompact}" />
                                <DataGridTemplateColumn Width="0.9*" MinWidth="110" Header="Kategorie">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,5" CornerRadius="13" Background="{Binding CategoryBadgeBackground}">
                                                <TextBlock HorizontalAlignment="Center" Text="{Binding CategoryLabel}" Foreground="{Binding CategoryBadgeForeground}" FontWeight="SemiBold" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="0.82*" MinWidth="100" Header="Status">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,5" CornerRadius="13" Background="{Binding StatusBadgeBackground}">
                                                <TextBlock HorizontalAlignment="Center" Text="{Binding StatusLabel}" Foreground="{Binding StatusBadgeForeground}" FontWeight="SemiBold" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
