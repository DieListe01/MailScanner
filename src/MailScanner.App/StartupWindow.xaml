<Window x:Class="MailScanner.App.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MailScanner wird gestartet"
        Width="420"
        Height="220"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True">
    <Border Background="#171B22"
            BorderBrush="#334152"
            BorderThickness="1"
            CornerRadius="18"
            Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Width="44"
                    Height="44"
                    CornerRadius="12"
                    Background="#1F2B3D"
                    BorderBrush="#4E86FF"
                    BorderThickness="1"
                    HorizontalAlignment="Left">
                <Viewbox Margin="10">
                    <Grid Width="24" Height="24">
                        <Path Data="M3,5 L12,11 L21,5 M4,6 L4,18 L20,18 L20,6"
                              Stroke="#D8E6FF"
                              StrokeThickness="1.8"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"/>
                    </Grid>
                </Viewbox>
            </Border>

            <TextBlock Grid.Row="1"
                       Margin="0,18,0,0"
                       Text="MailScanner startet"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="White"/>

            <TextBlock Grid.Row="2"
                       Margin="0,10,0,0"
                       Text="Einstellungen, Datenbank und Arbeitsbereiche werden vorbereitet."
                       FontSize="12.5"
                       Foreground="#B6C3D8"
                       TextWrapping="Wrap"/>

            <Border Grid.Row="2"
                    Margin="0,54,0,0"
                    HorizontalAlignment="Left"
                    Background="#111723"
                    BorderBrush="#3B4B65"
                    BorderThickness="1"
                    CornerRadius="999"
                    Padding="10,4">
                <TextBlock Text="{Binding VersionLabel}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#D7E5FF"/>
            </Border>

            <StackPanel Grid.Row="3" VerticalAlignment="Bottom">
                <ProgressBar IsIndeterminate="True"
                             Height="8"
                             Margin="0,0,0,12"
                             Background="#10141A"
                             Foreground="#4E86FF"/>
                <TextBlock Text="Bitte einen Moment warten..."
                           FontSize="11.5"
                           Foreground="#90A0B9"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
