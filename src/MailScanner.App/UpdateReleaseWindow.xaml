<Window x:Class="MailScanner.App.UpdateReleaseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update verfuegbar"
        Height="640"
        Width="800"
        MinHeight="580"
        MinWidth="700"
        WindowStartupLocation="CenterOwner"
        Background="#EAF2FD"
        ResizeMode="NoResize">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="28" CornerRadius="30">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#16395F" />
                    <GradientStop Offset="0.55" Color="#245A92" />
                    <GradientStop Offset="1" Color="#183E66" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Neue Version verfuegbar"
                               FontFamily="Bahnschrift"
                               FontSize="32"
                               FontWeight="SemiBold"
                               Foreground="#F5FBFF" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding VersionSummary}"
                               Foreground="#D9E8FA"
                               FontSize="15" />
                    <TextBlock Margin="0,12,0,0"
                               Text="{Binding InstallerSummary}"
                               Foreground="#C8DCF4"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                    <Border Padding="14,10" CornerRadius="16" Background="#25578E">
                        <TextBlock Text="GitHub Release"
                                   Foreground="#F4FAFF"
                                   FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,18,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Padding="20" CornerRadius="26" Background="#F8FBFF" BorderBrush="#D8E4F1" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Was passiert jetzt?"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#17314E" />
                    <Border Margin="0,16,0,10" Padding="12,10" CornerRadius="16" Background="#EEF5FF">
                        <TextBlock Text="1. Installer herunterladen" Foreground="#345E87" />
                    </Border>
                    <Border Margin="0,0,0,10" Padding="12,10" CornerRadius="16" Background="#EEF5FF">
                        <TextBlock Text="2. Setup starten" Foreground="#345E87" />
                    </Border>
                    <Border Padding="12,10" CornerRadius="16" Background="#EEF5FF">
                        <TextBlock Text="3. MailScanner aktualisieren" Foreground="#345E87" />
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Padding="24" CornerRadius="26" Background="#FBFDFF" BorderBrush="#D8E4F1" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Release-Notizen"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#17314E" />
                    <TextBlock Grid.Row="1"
                               Margin="0,8,0,0"
                               Text="{Binding ReleaseTitle}"
                               Foreground="#5E7896"
                               FontSize="14" />
                    <Border Grid.Row="2"
                            Margin="0,16,0,0"
                            Padding="18"
                            CornerRadius="20"
                            Background="#F1F7FF"
                            BorderBrush="#D8E5F4"
                            BorderThickness="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding ReleaseNotes}"
                                       TextWrapping="Wrap"
                                       LineHeight="24"
                                       Foreground="#244361" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Padding="12,10" CornerRadius="16" Background="#EEF5FF" BorderBrush="#D9E6F4" BorderThickness="1">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#476887" TextWrapping="Wrap" />
            </Border>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Width="150" Height="42" Margin="0,0,12,0" Click="OnOpenReleasePageClicked" Background="#6D97C9" BorderBrush="#9FBDDE" Content="Release-Seite" />
                <Button Width="180" Height="42" Margin="0,0,12,0" Click="OnInstallUpdateClicked" Background="#2F6BAA" BorderBrush="#6A98C9" Content="Update laden" />
                <Button Width="120" Height="42" Click="OnCloseClicked" Background="#8098B4" BorderBrush="#AABDD1" Content="Spaeter" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
