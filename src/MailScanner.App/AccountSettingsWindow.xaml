<Window x:Class="MailScanner.App.AccountSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/exprese/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:MailScanner.App.Controls"
        mc:Ignorable="d"
        Title="Mailkonten verwalten"
        Height="820"
        Width="1260"
        MinHeight="760"
        MinWidth="1120"
        WindowStartupLocation="CenterOwner"
        Background="#EEF3FB">
    <Window.Resources>
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="10" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="#FBFDFF" />
            <Setter Property="BorderBrush" Value="#D8E4F2" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#486581" />
        </Style>



        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Padding="12"
                                CornerRadius="8"
                                Background="#F4F8FD"
                                BorderBrush="#D7E4F1"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Status indicator -->
                                <Ellipse Width="10" Height="10"
                                         Fill="#9E9E9E"
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0"/>
                                <!-- Details -->
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontWeight="SemiBold"
                                               Foreground="#21415F"/>
                                    <TextBlock Text="{Binding EmailAddress}"
                                               Foreground="#7890A7"
                                               FontSize="12"/>
                                </StackPanel>
                                <!-- Provider badge -->
                                <Border Grid.Column="2"
                                        Background="#E9F2FD"
                                        CornerRadius="6"
                                        Padding="4,2"
                                        Margin="8,0,0,0">
                                    <TextBlock Text="{Binding ProviderName}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="#335B83"/>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#A9C5E4" />
                                <Setter TargetName="Root" Property="Background" Value="#F7FBFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#DDEBFA" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#7FA7D1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="26" CornerRadius="30" Background="#20384D">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="340" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Konten-Setup"
                               FontFamily="Bahnschrift"
                               FontSize="34"
                               FontWeight="SemiBold"
                               Foreground="#FFF8F0" />
                    <TextBlock Margin="0,10,0,0"
                               MaxWidth="620"
                               Text="Verwalte IMAP-Konten, Anmeldedaten, Scanbereich und Ordnerregeln in einer zentralen Konfiguration."
                               FontSize="15"
                               Foreground="#D3E3EF"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="16,14"
                        CornerRadius="18"
                        Background="#2D536F"
                        BorderBrush="#4B7391"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Gespeichert im Benutzerprofil"
                                   FontWeight="SemiBold"
                                   Foreground="#F5FAFF" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding SettingsStorageSummary}"
                                   Foreground="#D7E8F5"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,20,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Background="#F9FBFF">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Mailkonten"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="#203A57" />
                        <TextBlock Margin="0,5,0,0"
                                   Text="Waehle ein Konto oder lege ein neues Profil an."
                                   Foreground="#6D86A0"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <ListBox Grid.Row="1"
                             Margin="0,18,0,18"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemsSource="{Binding Accounts}"
                             SelectedItem="{Binding SelectedAccount}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#21415F" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="{Binding EmailAddress}"
                                                   Foreground="#7890A7"
                                                   FontSize="12" />
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Padding="9,4"
                                            CornerRadius="999"
                                            Background="#E9F2FD"
                                            BorderBrush="#C8DAEE"
                                            BorderThickness="1">
                                        <TextBlock Text="{Binding ProviderName}"
                                                   Foreground="#335B83"
                                                   FontSize="11"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                     <StackPanel Grid.Row="2">
                         <Button Height="42" Margin="0,0,0,10" Click="OnAddAccountClicked" Content="Neues Konto" Style="{StaticResource SecondaryActionButton}" />
                         <Button Height="42" Click="OnRemoveAccountClicked" Style="{StaticResource DangerActionButton}" Content="Ausgewaehltes Konto entfernen" />
                     </StackPanel>
                </Grid>
            </Border>

        <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

<StackPanel>
    <TextBlock Text="Details zum Konto"
            FontSize="24"
            FontWeight="SemiBold"
            Foreground="#203A57" />
    <TextBlock Margin="0,5,0,0"
            Text="Adresse, Zugangsdaten, Scanordner und Provider-Vorgaben."
            Foreground="#6D86A0" />
</StackPanel>

    <StackPanel Grid.Column="1">
        <controls:StatusBanner Message="{Binding ValidationMessage}"
                               State="{Binding ValidationBannerState}"
                               Margin="0,0,0,8" />
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <Button Width="160" Height="42" Margin="0,0,12,0" Click="OnSaveClicked" Content="Speichern" IsEnabled="{Binding CanSaveTest}" />
            <Button Width="176" Height="42" Margin="0,0,12,0" Click="OnTestSelectedClicked" Content="Ausgewaehltes testen" IsEnabled="{Binding CanSaveTest}" />
            <Button Width="160" Height="42" Style="{StaticResource SecondaryActionButton}" Click="OnTestAllClicked" Content="Alle testen" IsEnabled="{Binding CanSaveTest}" />
        </StackPanel>
        <TextBlock Text="{Binding StatusMessage}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,4"
                   FontSize="12"
                   Foreground="DarkGray" />
        <TextBlock Text="{Binding TestResultSummary}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,0"
                   FontSize="11"
                   Foreground="#666666" />
    </StackPanel>
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  Margin="0,22,0,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <!-- Database and Document paths -->
        <Border Style="{StaticResource SectionCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="270" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Datenbank-Pfad" />
                    <controls:FilePathPickerControl Path="{Binding DatabasePath, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" />
                </StackPanel>
                <TextBlock Grid.Column="2"
                            VerticalAlignment="Center"
                            Text="Vollständiger Pfad zur SQLite-Datenbankdatei (mailscanner.db). Beispiel: Z:\MailScanner\storage\mailscanner.db"
                            Foreground="#6C8096"
                            TextWrapping="Wrap" />
            </Grid>
        </Border>

<Border Margin="0,16,0,0" Style="{StaticResource SectionCardStyle}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel>
            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Dokumenten-Ordner" />
            <controls:FolderPathPickerControl Path="{Binding DocumentRootPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" />
        </StackPanel>
        <TextBlock Grid.Column="2"
                    VerticalAlignment="Center"
                    Text="Ordner wo gescannte PDF-Anhänge gespeichert werden. Beispiel: Z:\MailScanner\documents"
                    Foreground="#6C8096"
                    TextWrapping="Wrap" />
    </Grid>
</Border>

                            <Border Style="{StaticResource SectionCardStyle}" Background="#F7FAFE">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="270" />
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Rueckblick beim Erstscan" />
                                        <TextBox Margin="0,8,0,0"
                                                 Width="150"
                                                 Text="{Binding InitialLookbackDays, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                               VerticalAlignment="Center"
                                               Text="0 bedeutet kompletter Verlauf. Sonst werden beim ersten Scan nur die letzten X Tage geladen, solange noch kein gespeicherter Stand vorhanden ist."
                                               Foreground="#6C8096"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </Border>

                            <Border Margin="0,16,0,0" Style="{StaticResource SectionCardStyle}" Background="#F5F9FF">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="360" />
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Globale Ordner ausschliessen" />
                                        <TextBox Margin="0,8,0,0"
                                                 MinHeight="106"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Text="{Binding ExcludedFolderPatternsText, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <Border Grid.Column="2"
                                            Padding="16"
                                            CornerRadius="16"
                                            Background="#EAF3FF"
                                            BorderBrush="#D4E3F4"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Regel" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Text="Je Zeile ein Ordnerbegriff wie Spam, Trash, Sent oder Gesendet. Ordner mit passendem Namen werden beim Scan ausgelassen."
                                                       Foreground="#55708E"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Margin="0,16,0,0" Style="{StaticResource SectionCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="320" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Mailanbieter" />
                                        <ComboBox Margin="0,8,0,0"
                                                  ItemsSource="{Binding ProviderNames}"
                                                  SelectedItem="{Binding SelectedAccount.ProviderName, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectionChanged="OnProviderSelectionChanged" />
                                    </StackPanel>
                                    <Border Grid.Column="2"
                                            Padding="16"
                                            CornerRadius="16"
                                            Background="#FFF7EC"
                                            BorderBrush="#F0DEC1"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Provider-Hinweis" Style="{StaticResource FieldLabelStyle}" Foreground="#8A653E" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Text="{Binding SelectedProviderHint}"
                                                       Foreground="#8A653E"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Identitaet" FontSize="18" FontWeight="SemiBold" Foreground="#203A57" />
                                        <Grid Margin="0,16,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Anzeigename" />
                                            <TextBox Grid.Row="1" Margin="0,8,0,14" Text="{Binding SelectedAccount.DisplayName, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Grid.Row="2" Style="{StaticResource FieldLabelStyle}" Text="E-Mail-Adresse" />
                                            <TextBox Grid.Row="3" Margin="0,8,0,14" Text="{Binding SelectedAccount.EmailAddress, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Grid.Row="4" Style="{StaticResource FieldLabelStyle}" Text="Benutzername" />
                                            <TextBox Grid.Row="5" Margin="0,8,0,0" Text="{Binding SelectedAccount.UserName, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Server und Login" FontSize="18" FontWeight="SemiBold" Foreground="#203A57" />
                                        <Grid Margin="0,16,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Passwort / App-Passwort" />
                                            <PasswordBox x:Name="PasswordInput" Grid.Row="1" Margin="0,8,0,14" PasswordChanged="OnPasswordChanged" />
                                            <TextBlock Grid.Row="2" Style="{StaticResource FieldLabelStyle}" Text="IMAP-Host" />
                                            <TextBox Grid.Row="3" Margin="0,8,0,14" Text="{Binding SelectedAccount.ImapHost, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Grid.Row="4" Style="{StaticResource FieldLabelStyle}" Text="Port" />
                                            <TextBox Grid.Row="5" Margin="0,8,0,14" Text="{Binding SelectedAccount.ImapPort, UpdateSourceTrigger=PropertyChanged}" />
                                            <CheckBox Grid.Row="6" Margin="0,0,0,0" IsChecked="{Binding SelectedAccount.UseSsl}" Content="SSL verwenden" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="320" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Scan-Zielordner" FontSize="18" FontWeight="SemiBold" Foreground="#203A57" />
                                        <TextBlock Margin="0,5,0,0" Text="Welcher IMAP-Ordner soll durchsucht werden?" Foreground="#6D86A0" />
                                        <TextBox Margin="0,16,0,0" Text="{Binding SelectedAccount.FolderName, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}" Background="#F7FAFE">
                                    <StackPanel>
                                        <TextBlock Text="Konto-spezifische Ausschluesse" FontSize="18" FontWeight="SemiBold" Foreground="#203A57" />
                                        <TextBlock Margin="0,5,0,0"
                                                   Text="Diese Regeln gelten nur fuer das ausgewaehlte Konto und ergaenzen die globalen Ausschluesse."
                                                   Foreground="#6D86A0"
                                                   TextWrapping="Wrap" />
                                        <TextBox Margin="0,16,0,0"
                                                 MinHeight="106"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Text="{Binding SelectedAccount.ExcludedFolderPatternsText, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
