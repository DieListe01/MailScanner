<Window x:Class="MailScanner.AccountSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="MailScanner - Konto-Einstellungen"
        Width="1380"
        Height="900"
        MinWidth="1140"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource AppBackgroundBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="AccountListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="0,0,0,10"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ItemBorder"
                                            Background="#1D2028"
                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border x:Name="SelectionIndicator"
                                                    Width="3"
                                                    Margin="0,2,10,2"
                                                    CornerRadius="2"
                                                    Background="{StaticResource AccentBrush}"
                                                    Opacity="0"/>
                                            <ContentPresenter Grid.Column="1"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource BorderBrushStrong}"/>
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#232833"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource SelectionBrush}"/>
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                            <Setter TargetName="SelectionIndicator" Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="12"
            Background="{StaticResource ChromeBrush}"
            BorderBrush="{StaticResource BorderBrushStrong}"
            BorderThickness="1"
            CornerRadius="18"
            Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource TitleBarBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="18,18,0,0">
                <Grid MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                        <Border Style="{StaticResource HeaderIconTile}">
                            <Grid Margin="5">
                                <Path Data="M 3 3 L 11 3 M 3 9 L 11 9 M 5 1.5 L 5 4.5 M 8 7.5 L 8 10.5"
                                      Stroke="#C5D8FF"
                                      StrokeThickness="1.4"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"/>
                            </Grid>
                        </Border>
                        <TextBlock Text="MailScanner" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Margin="18,0,18,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="11"
                               Text="{Binding StatusMessage}"
                               TextTrimming="CharacterEllipsis"/>

                    <Border Grid.Column="2"
                            Margin="0,0,10,0"
                            Style="{StaticResource TitlePill}"
                            VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="Konto-Einstellungen" FontSize="11" FontWeight="SemiBold" Foreground="#D9E6FF"/>
                    </Border>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource WindowControlButton}" Click="OnMinimizeWindowClicked" Content="-"/>
                        <Button Style="{StaticResource WindowControlButton}" Click="OnToggleMaximizeWindowClicked" Content="[]"/>
                        <Button Style="{StaticResource WindowControlButton}" Click="OnCloseWindowClicked" Content="X"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="176"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.RowSpan="2"
                        Grid.Column="0"
                        Background="{StaticResource SidebarBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="14">
                    <Grid Margin="14,18,14,18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="SETTINGS" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock Text="Konten" Margin="0,6,0,0" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Postfaecher, IMAP-Daten und Speicherorte in einer kompakten Verwaltungsebene." Margin="0,8,0,0" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,24,0,0">
                            <Button Style="{StaticResource NavigationButtonActive}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource SidebarIconTileActive}">
                                        <Viewbox Margin="5">
                                            <Grid Width="12" Height="12">
                                                <Ellipse Width="4.8" Height="4.8" Stroke="White" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                                                <Path Data="M 1.5 11 C 2.4 8.4 9.6 8.4 10.5 11" Stroke="White" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            </Grid>
                                        </Viewbox>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Konten" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </Grid>
                            </Button>

                            <Button Style="{StaticResource NavigationButton}" Click="OnAddAccountClicked">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource SidebarIconTile}">
                                        <Viewbox Margin="5">
                                            <Path Data="M 6 1.5 L 6 10.5 M 1.5 6 L 10.5 6" Stroke="#C6CEDC" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Viewbox>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Neues Konto" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </Grid>
                            </Button>

                            <Button Style="{StaticResource NavigationButton}" Click="OnDebugClicked">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource SidebarIconTile}">
                                        <Viewbox Margin="5">
                                            <Grid Width="12" Height="12">
                                                <Path Data="M 0 1 L 4 4 L 0 7" Stroke="#C6CEDC" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                <Rectangle Width="5" Height="1.4" Fill="#C6CEDC" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,4,0,0"/>
                                            </Grid>
                                        </Viewbox>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Debug" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </Grid>
                            </Button>
                        </StackPanel>

                        <Border Grid.Row="3" Style="{StaticResource SurfaceCard}" Background="#1E222B" Padding="12">
                            <StackPanel>
                                <TextBlock Text="SPEICHERORT" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                                <TextBlock Text="{Binding SettingsStorageSummary}" Margin="0,8,0,0" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource SurfaceCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="Konto-Explorer" Style="{StaticResource SectionTitle}" Margin="0"/>
                            <TextBlock Text="Bestehende Eintraege waehlen oder neue Konten vorbereiten" Margin="0,6,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <ListBox x:Name="AccountsListBox"
                                 Grid.Row="1"
                                 Style="{StaticResource AccountListStyle}"
                                 ItemsSource="{Binding Accounts}"
                                 SelectedItem="{Binding SelectedAccount}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="32" Height="32" Background="#212838" BorderBrush="#4E648A" BorderThickness="1" CornerRadius="8" VerticalAlignment="Top">
                                            <TextBlock Text="@" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#A9C7FF" FontWeight="SemiBold"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding EmailAddress}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding ImapHost}" FontSize="10" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Grid.Row="2" Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="+" Style="{StaticResource ToolbarIconButton}" ToolTip="Neues Konto" Click="OnAddAccountClicked"/>
                            <Button Grid.Column="1" Content="-" Style="{StaticResource ToolbarIconButton}" Margin="8,0,0,0" ToolTip="Konto loeschen" Click="OnRemoveAccountClicked"/>
                            <TextBlock Grid.Column="2" Text="Ausgewaehltes Konto bearbeiten" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                        </Grid>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Column="4" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0" Grid.ColumnSpan="3" Style="{StaticResource SurfaceCard}" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="300"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{Binding StatusMessage}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding SettingsStorageSummary}" Margin="0,8,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                </StackPanel>

                                <Button Grid.Column="1" Content="Debug" Style="{StaticResource ToolButton}" Width="92" HorizontalAlignment="Right" Click="OnDebugClicked"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Grid.ColumnSpan="3" Background="{StaticResource HeroBrush}" BorderBrush="#334152" BorderThickness="1" CornerRadius="16" Padding="22" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="290"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="AKTIVES KONTO" FontSize="10" FontWeight="SemiBold" Foreground="#9DB6E6"/>
                                    <TextBlock Text="{Binding SelectedAccount.DisplayName}" Margin="0,8,0,0" FontSize="28" FontWeight="SemiBold" Foreground="White" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding SelectedAccount.EmailAddress}" Margin="0,8,0,0" FontSize="13" Foreground="#D4DCEE" TextWrapping="Wrap"/>
                                    <WrapPanel Margin="0,14,0,0">
                                        <Border Style="{StaticResource ChipBorder}" Background="#1D2430" BorderBrush="#4C5D80">
                                            <TextBlock Text="IMAP" FontSize="11" Foreground="#D9E6FF"/>
                                        </Border>
                                        <Border Style="{StaticResource ChipBorder}" Background="#1D2430" BorderBrush="#4C5D80">
                                            <TextBlock Text="{Binding SelectedAccount.ImapHost}" FontSize="11" Foreground="#D9E6FF"/>
                                        </Border>
                                        <Border Style="{StaticResource ChipBorder}" Background="#1D2430" BorderBrush="#4C5D80">
                                            <TextBlock Text="{Binding SelectedAccount.FolderName}" FontSize="11" Foreground="#D9E6FF"/>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>

                                <Border Grid.Column="1" Background="#1A202B" BorderBrush="#3A475C" BorderThickness="1" CornerRadius="14" Padding="14" Margin="24,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Hinweis" FontSize="12" FontWeight="SemiBold" Foreground="#D9E6FF"/>
                                        <TextBlock Text="Fuer Gmail wird in der Regel ein App-Passwort benoetigt, wenn 2-Faktor-Authentifizierung aktiv ist." Margin="0,8,0,0" FontSize="11" Foreground="#D3DEEF" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource SurfaceCard}" Margin="0,0,0,14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Konto" Style="{StaticResource SectionTitle}" Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Anzeigename" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="DisplayNameTextBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource InputTextBox}" Text="{Binding SelectedAccount.DisplayName, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,14,0,0" Text="E-Mail" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="EmailAddressTextBox" Grid.Row="2" Grid.Column="1" Margin="0,14,0,0" Style="{StaticResource InputTextBox}" Text="{Binding SelectedAccount.EmailAddress, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,14,0,0" Text="Benutzername" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="UserNameTextBox" Grid.Row="3" Grid.Column="1" Margin="0,14,0,0" Style="{StaticResource InputTextBox}" Text="{Binding SelectedAccount.UserName, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,14,0,0" Text="Passwort" Style="{StaticResource FieldLabel}"/>
                                <PasswordBox x:Name="PasswordBox" Grid.Row="4" Grid.Column="1" Margin="0,14,0,0" Style="{StaticResource InputPasswordBox}" PasswordChanged="OnPasswordChanged"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource SurfaceCard}" Margin="0,0,0,14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="IMAP-Einstellungen" Style="{StaticResource SectionTitle}" Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Server" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="ImapHostTextBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource InputTextBox}" Text="{Binding SelectedAccount.ImapHost, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,14,0,0" Text="Port" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="ImapPortTextBox" Grid.Row="2" Grid.Column="1" Margin="0,14,0,0" Width="140" HorizontalAlignment="Left" Style="{StaticResource InputTextBox}" Text="{Binding SelectedAccount.ImapPort}"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,14,0,0" Text="Ordner" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="FolderNameTextBox" Grid.Row="3" Grid.Column="1" Margin="0,14,0,0" Style="{StaticResource InputTextBox}" Text="{Binding SelectedAccount.FolderName, UpdateSourceTrigger=PropertyChanged}"/>

                                <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Margin="0,16,0,0">
                                    <CheckBox x:Name="UseSslCheckBox" Content="SSL verwenden" Style="{StaticResource InputCheckBox}" IsChecked="{Binding SelectedAccount.UseSsl}"/>
                                    <Border Style="{StaticResource InsetCard}" Margin="0,14,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Best Practice" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="Fuer produktive Postfaecher empfehlen sich IMAP ueber 993, SSL und ein dedizierter Zielordner wie INBOX." Margin="0,8,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource SurfaceCard}">
                            <StackPanel>
                                <TextBlock Text="Globale Einstellungen" Style="{StaticResource SectionTitle}"/>

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Lookback" Style="{StaticResource FieldLabel}" Margin="0,9,0,0"/>
                                    <TextBox x:Name="LookbackDaysTextBox" Grid.Column="1" Width="104" Style="{StaticResource InputTextBox}" Text="{Binding InitialLookbackDays}"/>
                                    <TextBlock Grid.Column="2" Text="Tage" Margin="12,9,0,0" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Grid>

                                <TextBlock Text="Ausgeschlossene Ordner / Muster" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding ExcludedFolderPatternsText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputTextBox}"
                                         Height="168"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         TextWrapping="Wrap"/>
                                <TextBlock Text="Jede Zeile entspricht einem Muster oder Ordner, der beim Scan uebersprungen wird." Margin="0,10,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="3" Grid.Column="2" Style="{StaticResource SurfaceCard}">
                            <StackPanel>
                                <TextBlock Text="Speicherorte" Style="{StaticResource SectionTitle}"/>

                                <TextBlock Text="Datenbank" Style="{StaticResource FieldLabel}"/>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="DatabasePathTextBox" Grid.Column="0" Style="{StaticResource InputTextBox}" Text="{Binding DatabasePath}" IsReadOnly="True"/>
                                    <Button Grid.Column="1" Content="..." Style="{StaticResource ToolbarIconButton}" Margin="8,0,0,0" Click="OnBrowseDatabaseClicked"/>
                                </Grid>

                                <TextBlock Text="Dokumentenordner" Style="{StaticResource FieldLabel}"/>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="DocumentRootPathTextBox" Grid.Column="0" Style="{StaticResource InputTextBox}" Text="{Binding DocumentRootPath}" IsReadOnly="True"/>
                                    <Button Grid.Column="1" Content="..." Style="{StaticResource ToolbarIconButton}" Margin="8,0,0,0" Click="OnBrowseDocumentClicked"/>
                                </Grid>

                                <Border Style="{StaticResource InsetCard}">
                                    <StackPanel>
                                        <TextBlock Text="Tipp" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="Verwende kurze, stabile Speicherpfade, damit Downloads und lokale Vorschauen zuverlaessig funktionieren." Margin="0,8,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>

                <Border Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="3" Style="{StaticResource SurfaceCard}" Padding="16,14" Margin="0,16,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Aenderungen zuerst testen, danach speichern." FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="Die Einstellungen werden direkt in deinen lokalen App-Daten abgelegt." Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Schliessen" Style="{StaticResource ToolButton}" Margin="0,0,10,0" Click="OnCloseClicked"/>
                            <Button Content="Dieses Konto testen" Style="{StaticResource ToolButton}" Margin="0,0,10,0" Click="OnTestSelectedClicked" IsEnabled="{Binding CanSaveTest}"/>
                            <Button Content="Alle testen" Style="{StaticResource ToolButton}" Margin="0,0,10,0" Click="OnTestAllClicked" IsEnabled="{Binding CanSaveTest}"/>
                            <Button Content="Speichern" Style="{StaticResource ToolPrimaryButton}" Click="OnSaveClicked" IsEnabled="{Binding CanSaveTest}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
