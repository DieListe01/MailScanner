<Window x:Class="MailScanner.DebugOutputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="MailScanner - Debug Output"
        Width="1180"
        Height="800"
        MinWidth="940"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource AppBackgroundBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Margin="12"
            Background="{StaticResource ChromeBrush}"
            BorderBrush="{StaticResource BorderBrushStrong}"
            BorderThickness="1"
            CornerRadius="18"
            Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource TitleBarBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="18,18,0,0">
                <Grid MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                        <Border Style="{StaticResource HeaderIconTile}">
                            <Grid Margin="7,6">
                                <Path Data="M 0 1 L 4 4 L 0 7" Stroke="#C5D8FF" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <Rectangle Width="5" Height="1.4" Fill="#C5D8FF" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,4,0,0"/>
                            </Grid>
                        </Border>
                        <TextBlock Text="Debug Console" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Margin="18,0,18,0"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="{StaticResource MutedBrush}"
                               Text="Live-Streams fuer Registry, Settings, allgemeine Meldungen und Fehler."/>

                    <Border Grid.Column="2" Style="{StaticResource TitlePill}" Margin="0,0,10,0" VerticalAlignment="Center" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="Diagnostics" FontSize="11" FontWeight="SemiBold" Foreground="#D9E6FF"/>
                    </Border>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource WindowControlButton}" Click="OnMinimizeWindowClicked" Content="-"/>
                        <Button Style="{StaticResource WindowControlButton}" Click="OnToggleMaximizeWindowClicked" Content="[]"/>
                        <Button Style="{StaticResource WindowControlButton}" Click="OnCloseWindowClicked" Content="X"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource HeroBrush}" BorderBrush="#334152" BorderThickness="1" CornerRadius="16" Padding="22" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="290"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="DIAGNOSTIC WORKSPACE" Style="{StaticResource SmallCaption}" Foreground="#A9C2F3"/>
                            <TextBlock Text="Debug Output" Margin="0,8,0,0" FontSize="30" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Fehler, Konfiguration und Laufzeitdetails ohne modal blockierende Dialoge verfolgen." Margin="0,8,0,0" FontSize="13" Foreground="#D6DEEF" TextWrapping="Wrap"/>
                        </StackPanel>

                        <Border Grid.Column="1" Margin="24,0,0,0" Background="#1B2230" BorderBrush="#34518A" BorderThickness="1" CornerRadius="14" Padding="14">
                            <StackPanel>
                                <TextBlock Text="Log-Modi" FontSize="11" FontWeight="SemiBold" Foreground="#BED1F4"/>
                                <WrapPanel Margin="0,10,0,0">
                                    <Border Style="{StaticResource ChipBorder}" Background="#18202B" BorderBrush="#42577D">
                                        <TextBlock Text="Allgemein" FontSize="11" Foreground="#D9E6FF"/>
                                    </Border>
                                    <Border Style="{StaticResource ChipBorder}" Background="#18202B" BorderBrush="#42577D">
                                        <TextBlock Text="Registry" FontSize="11" Foreground="#D9E6FF"/>
                                    </Border>
                                    <Border Style="{StaticResource ChipBorder}" Background="#18202B" BorderBrush="#42577D">
                                        <TextBlock Text="Settings" FontSize="11" Foreground="#D9E6FF"/>
                                    </Border>
                                    <Border Style="{StaticResource ChipBorder}" Background="#2A1B22" BorderBrush="#734349">
                                        <TextBlock Text="Fehler" FontSize="11" Foreground="#FFD7DA"/>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource SurfaceCard}" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Werkzeuge" Style="{StaticResource SectionTitle}" Margin="0"/>
                            <TextBlock Text="Der aktive Tab kann direkt kopiert oder geleert werden." Margin="0,6,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                        </StackPanel>
                        <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="Kopieren" Style="{StaticResource ToolButton}" Margin="0,0,8,0" Click="OnCopyClicked"/>
                            <Button Content="Leeren" Style="{StaticResource ToolDangerButton}" Click="OnClearClicked"/>
                        </WrapPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource SurfaceCard}" Padding="0">
                    <TabControl x:Name="DebugTabs" Margin="14,14,14,0">
                        <TabItem Header="Allgemein">
                            <Border Margin="0,12,0,0" Style="{StaticResource InsetCard}" Padding="0">
                                <TextBox x:Name="GeneralOutput"
                                         IsReadOnly="True"
                                         Background="{StaticResource CodeBackgroundBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         BorderThickness="0"
                                         Padding="16"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"/>
                            </Border>
                        </TabItem>
                        <TabItem Header="Registry">
                            <Border Margin="0,12,0,0" Style="{StaticResource InsetCard}" Padding="0">
                                <TextBox x:Name="RegistryOutput"
                                         IsReadOnly="True"
                                         Background="{StaticResource CodeBackgroundBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         BorderThickness="0"
                                         Padding="16"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"/>
                            </Border>
                        </TabItem>
                        <TabItem Header="Settings">
                            <Border Margin="0,12,0,0" Style="{StaticResource InsetCard}" Padding="0">
                                <TextBox x:Name="SettingsOutput"
                                         IsReadOnly="True"
                                         Background="{StaticResource CodeBackgroundBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         BorderThickness="0"
                                         Padding="16"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"/>
                            </Border>
                        </TabItem>
                        <TabItem Header="Fehler">
                            <Border Margin="0,12,0,0" Style="{StaticResource InsetCard}" Padding="0" BorderBrush="#6C3E46">
                                <TextBox x:Name="ErrorOutput"
                                         IsReadOnly="True"
                                         Background="#190F12"
                                         Foreground="#FFD7DA"
                                         BorderThickness="0"
                                         Padding="16"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"/>
                            </Border>
                        </TabItem>
                    </TabControl>
                </Border>

                <Border Grid.Row="3" Style="{StaticResource SurfaceCard}" Padding="16,12" Margin="0,14,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Name="StatusText" Text="Bereit" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" x:Name="TimestampText" Text="" FontSize="11" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
