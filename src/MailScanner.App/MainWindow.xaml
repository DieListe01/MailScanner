<Window x:Class="MailScanner.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="MailScanner"
        Width="1480"
        Height="940"
        MinWidth="1260"
        MinHeight="820"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource AppBackgroundBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Margin="12"
            Background="{StaticResource ChromeBrush}"
            BorderBrush="{StaticResource BorderBrushStrong}"
            BorderThickness="1"
            CornerRadius="18"
            Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource TitleBarBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="18,18,0,0">
                <Grid MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                        <Border Style="{StaticResource HeaderIconTile}">
                            <Grid Margin="5">
                                <Path Data="M 2 4 L 12 4 L 12 11 L 2 11 Z M 2 4 L 7 8 L 12 4"
                                      Stroke="#C5D8FF"
                                      StrokeThickness="1.25"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Stretch="Fill"/>
                            </Grid>
                        </Border>
                        <TextBlock Text="MailScanner" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Margin="18,0,18,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="11"
                               Text="{Binding BusyMessage}"
                               TextTrimming="CharacterEllipsis"/>

                    <Border Grid.Column="2"
                            Margin="0,0,10,0"
                            Style="{StaticResource TitlePill}"
                            VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="{Binding CurrentVersionSummary}" FontSize="11" FontWeight="SemiBold" Foreground="#D9E6FF"/>
                    </Border>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource WindowControlButton}" Click="OnMinimizeWindowClicked" Content="-"/>
                        <Button Style="{StaticResource WindowControlButton}" Click="OnToggleMaximizeWindowClicked" Content="[]"/>
                        <Button Style="{StaticResource WindowControlButton}" Click="OnCloseWindowClicked" Content="X"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="196"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource SidebarBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="0,0,1,0"
                        CornerRadius="0,0,0,18">
                    <Grid Margin="12,16,12,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="WORKSPACE" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock Text="MailScanner" Margin="0,6,0,0" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Scanner, Konten, Releases und Diagnose in einer kompakten Oberflaeche." Margin="0,7,0,0" FontSize="10.5" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,20,0,0" HorizontalAlignment="Stretch">
                            <Button x:Name="RefreshButton" Style="{StaticResource NavigationButton}" Click="OnScannerNavClicked">
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource SidebarIconTile}">
                                        <Viewbox Margin="5">
                                            <Grid Width="12" Height="12">
                                                <Ellipse Width="7" Height="7" Stroke="#C6CEDC" StrokeThickness="1.6" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                                <Path Data="M 7 7 L 11 11" Stroke="#C6CEDC" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            </Grid>
                                        </Viewbox>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Scannen" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </Grid>
                            </Button>

                            <Button x:Name="ResultsButton" Style="{StaticResource NavigationButton}" Click="OnResultsNavClicked">
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource SidebarIconTile}">
                                        <Viewbox Margin="5">
                                            <Grid Width="12" Height="12">
                                                <Rectangle Width="9" Height="9" Stroke="#C6CEDC" StrokeThickness="1.4" RadiusX="1" RadiusY="1"/>
                                                <Path Data="M 1 4.5 L 11 4.5 M 4.5 1 L 4.5 11" Stroke="#C6CEDC" StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            </Grid>
                                        </Viewbox>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Treffer" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </Grid>
                            </Button>

                            <Button x:Name="AccountButton" Style="{StaticResource NavigationButton}" Click="OnAccountSettingsClicked">
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource SidebarIconTile}">
                                        <Viewbox Margin="5">
                                            <Grid Width="12" Height="12">
                                                <Ellipse Width="4.8" Height="4.8" Stroke="#C6CEDC" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                                                <Path Data="M 1.5 11 C 2.4 8.4 9.6 8.4 10.5 11" Stroke="#C6CEDC" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            </Grid>
                                        </Viewbox>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Konten" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </Grid>
                            </Button>

                            <Button x:Name="ConnectionsButton" Style="{StaticResource NavigationButton}" Click="OnTestConnectionsClicked">
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource SidebarIconTile}">
                                        <Viewbox Margin="5">
                                            <Grid Width="12" Height="12">
                                                <Ellipse Width="2.8" Height="2.8" Fill="#C6CEDC" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                <Ellipse Width="2.8" Height="2.8" Fill="#C6CEDC" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                                <Ellipse Width="2.8" Height="2.8" Fill="#C6CEDC" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                                                <Path Data="M 3 6 L 8.5 2.6 M 3 6 L 8.5 9.4" Stroke="#C6CEDC" StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            </Grid>
                                        </Viewbox>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Verbindungen" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </Grid>
                            </Button>

                            <Button x:Name="UpdateButton" Style="{StaticResource NavigationButton}" Click="OnUpdateClicked">
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource SidebarIconTile}">
                                        <Viewbox Margin="5">
                                            <Grid Width="12" Height="12">
                                                <Path Data="M 6 1 L 6 7.5 M 3.5 5 L 6 7.5 L 8.5 5 M 2 10.5 L 10 10.5" Stroke="#C6CEDC" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                            </Grid>
                                        </Viewbox>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Update" VerticalAlignment="Center" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Button>

                            <Button x:Name="DebugButton" Style="{StaticResource NavigationButton}" Click="OnOpenDebugClicked">
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource SidebarIconTile}">
                                        <Viewbox Margin="5">
                                            <Grid Width="12" Height="12">
                                                <Path Data="M 0 1 L 4 4 L 0 7" Stroke="#C6CEDC" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                <Rectangle Width="5" Height="1.4" Fill="#C6CEDC" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,4,0,0"/>
                                            </Grid>
                                        </Viewbox>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Debug" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </Grid>
                            </Button>

                            <Button x:Name="StopButton" Style="{StaticResource NavigationButton}" Click="OnStopClicked" Visibility="{Binding BusyVisibility}" Margin="0,14,0,0">
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="22" Height="22" Background="#5B2A31" BorderBrush="#8C4E58" BorderThickness="1" CornerRadius="6">
                                        <Viewbox Margin="6">
                                            <Rectangle Width="8" Height="8" Fill="#FFD9DE" RadiusX="1" RadiusY="1"/>
                                        </Viewbox>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Stoppen" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </Grid>
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Row="3">
                            <Border Style="{StaticResource SurfaceCard}" Background="#1E222B" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="STATUS" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock Text="{Binding AccountCountSummary}" Margin="0,8,0,0" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding LatestVersionSummary}" Margin="0,6,0,0" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="18">
                    <Grid x:Name="ScannerWorkspace" Visibility="{Binding ScannerPageVisibility}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{StaticResource HeroBrush}" BorderBrush="#334152" BorderThickness="1" CornerRadius="16" Padding="18" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="320"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="SCANNER WORKSPACE" FontSize="10" FontWeight="SemiBold" Foreground="#9DB6E6"/>
                                    <TextBlock Text="MailScanner" Margin="0,6,0,0" FontSize="26" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Dokumentkandidaten aus E-Mails finden, priorisieren und lokal verwalten." Margin="0,6,0,0" FontSize="12" Foreground="#D4DCEE" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding StatusMessage}" Margin="0,14,0,0" FontSize="13" FontWeight="SemiBold" Foreground="White" TextWrapping="Wrap"/>

                                    <WrapPanel Margin="0,10,0,0">
                                        <Border Style="{StaticResource ChipBorder}" Background="#1D2430" BorderBrush="#4C5D80">
                                            <TextBlock Text="{Binding AccountCountSummary}" FontSize="11" Foreground="#D9E6FF"/>
                                        </Border>
                                        <Border Style="{StaticResource ChipBorder}" Background="#1D2430" BorderBrush="#4C5D80">
                                            <TextBlock Text="{Binding LookbackScopeSummary}" FontSize="11" Foreground="#D9E6FF"/>
                                        </Border>
                                        <Border Style="{StaticResource ChipBorder}" Background="#1D2430" BorderBrush="#4C5D80">
                                            <TextBlock Text="{Binding ExcludedFoldersSummary}" FontSize="11" Foreground="#D9E6FF"/>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="18,0,0,0">
                                    <Border Background="#1D2430" BorderBrush="#4E86FF" BorderThickness="1" CornerRadius="14" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="Release-Status" FontSize="11" FontWeight="SemiBold" Foreground="#B8CCF3"/>
                                            <TextBlock Text="{Binding LatestVersionSummary}" Margin="0,6,0,0" FontSize="15" FontWeight="SemiBold" Foreground="White" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding UpdateStatusSummary}" Margin="0,6,0,0" FontSize="10.5" Foreground="#D3DEEF" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="108"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#1A202B" BorderBrush="#3A475C" BorderThickness="1" CornerRadius="14" Padding="12" Margin="0,0,10,0">
                                            <StackPanel>
                                                <TextBlock Text="Verbindungstest" FontSize="11" FontWeight="SemiBold" Foreground="#B8CCF3"/>
                                                <TextBlock Text="{Binding LastConnectionTestSummary}" Margin="0,8,0,0" FontSize="11" Foreground="#D3DEEF" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                        <Button Grid.Column="1" Content="Scan starten" Style="{StaticResource ToolPrimaryButton}" Height="40" VerticalAlignment="Stretch" Click="OnRefreshClicked"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource RaisedCard}" BorderBrush="#3E5E99">
                                <StackPanel>
                                    <TextBlock Text="Konten" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding AccountCountSummary}" Style="{StaticResource MetricValueText}"/>
                                    <TextBlock Text="Konfigurierte Postfaecher" Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource RaisedCard}" BorderBrush="#3A6B5A">
                                <StackPanel>
                                    <TextBlock Text="Anhaenge" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding AttachmentMailSummary}" Style="{StaticResource MetricValueText}" Foreground="{StaticResource GreenBrush}"/>
                                    <TextBlock Text="Mails mit Anhang" Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4" Style="{StaticResource RaisedCard}" BorderBrush="#6B5933">
                                <StackPanel>
                                    <TextBlock Text="Dokumente" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding PdfCandidateSummary}" Style="{StaticResource MetricValueText}" Foreground="{StaticResource AmberBrush}"/>
                                    <TextBlock Text="PDF / DOC Treffer" Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="6" Style="{StaticResource RaisedCard}" BorderBrush="#734349">
                                <StackPanel>
                                    <TextBlock Text="Rechnungen" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding InvoiceMatchSummary}" Style="{StaticResource MetricValueText}" Foreground="{StaticResource RedBrush}"/>
                                    <TextBlock Text="Erkannte Rechnungen" Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="2" Style="{StaticResource SurfaceCard}" Margin="0,0,0,10" Visibility="{Binding BusyVisibility}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.7*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="1.0*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="1.15*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Live-Scan" Style="{StaticResource SectionTitle}" Margin="0"/>
                                        <Button Content="Stoppen" Style="{StaticResource ToolDangerButton}" Click="OnStopClicked" Width="90" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="74"/>
                                        </Grid.ColumnDefinitions>
                                        <ProgressBar Grid.Column="0" Value="{Binding ScanProgressPercentage}" Maximum="100" Margin="0,4,12,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding ScanProgressPercentage, StringFormat={}{0:F0}%}" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/>
                                    </Grid>

                                    <TextBlock Text="{Binding ScanProgressSummary}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding CurrentScanTarget}" Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>

                                    <Border Style="{StaticResource InsetCard}" Margin="0,12,0,0">
                                        <StackPanel>
                                            <TextBlock Text="{Binding LiveScanInfo}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding AccountSettingsInfo}" Margin="0,8,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <Border Grid.Column="2" Style="{StaticResource InsetCard}">
                                    <StackPanel>
                                        <TextBlock Text="Kennzahlen waehrend des Scans" Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Mails mit Anhang" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding AttachmentMailSummary}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource GreenBrush}"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Dokument-Treffer" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding PdfCandidateSummary}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AmberBrush}"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Rechnungs-Treffer" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding InvoiceMatchSummary}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource RedBrush}"/>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Aelteste Mail" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding OldestMailSummary}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource BlueBrush}" TextWrapping="Wrap"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="4" Style="{StaticResource InsetCard}" Padding="0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0" Background="#1A1E25" BorderBrush="#2F3642" BorderThickness="0,0,0,1" CornerRadius="12,12,0,0" Padding="12,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="Scan-Protokoll" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="Live-Events waehrend des Scans" Margin="0,4,0,0" FontSize="10.5" Foreground="{StaticResource MutedBrush}"/>
                                                </StackPanel>
                                                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <Button Content="Kopieren" Style="{StaticResource ToolButton}" Margin="0,0,6,0" Click="OnCopyLogClicked"/>
                                                    <Button Content="Leeren" Style="{StaticResource ToolDangerButton}" Click="OnClearLogClicked"/>
                                                </WrapPanel>
                                            </Grid>
                                        </Border>
                                        <TextBox Grid.Row="1"
                                                 Text="{Binding CompactLogText, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 Background="{StaticResource CodeBackgroundBrush}"
                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                 BorderThickness="0"
                                                 Padding="14"
                                                 FontFamily="Consolas"
                                                 FontSize="10.5"
                                                 Height="220"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 TextWrapping="NoWrap"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3" Style="{StaticResource SurfaceCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Naechster Schritt" Style="{StaticResource SectionTitle}" Margin="0"/>
                                    <TextBlock Text="Scannen und Treffer pruefen sind jetzt getrennt. Nach dem Lauf wechselst du in den Bereich 'Treffer' fuer Rechnungen, Dokumente und Vorschau." Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding SelectionInfo}" Margin="0,10,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="Treffer ansehen" Style="{StaticResource ToolPrimaryButton}" Margin="0,0,10,0" Click="OnResultsNavClicked"/>
                                    <Button Content="Konten" Style="{StaticResource ToolButton}" Click="OnAccountSettingsClicked"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid x:Name="ResultsWorkspace" Visibility="{Binding ResultsPageVisibility}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{StaticResource HeroBrush}" BorderBrush="#334152" BorderThickness="1" CornerRadius="16" Padding="18" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="320"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="TREFFER WORKSPACE" FontSize="10" FontWeight="SemiBold" Foreground="#9DB6E6"/>
                                    <TextBlock Text="Rechnungen und Dokumente" Margin="0,6,0,0" FontSize="26" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Hier pruefst du erkannte Treffer, oeffnest Vorschauen und laedst Dateien herunter." Margin="0,6,0,0" FontSize="12" Foreground="#D4DCEE" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding StatusMessage}" Margin="0,14,0,0" FontSize="13" FontWeight="SemiBold" Foreground="White" TextWrapping="Wrap"/>

                                    <WrapPanel Margin="0,10,0,0">
                                        <Border Style="{StaticResource ChipBorder}" Background="#1D2430" BorderBrush="#4C5D80">
                                            <TextBlock Text="{Binding PdfCandidateSummary}" FontSize="11" Foreground="#D9E6FF"/>
                                        </Border>
                                        <Border Style="{StaticResource ChipBorder}" Background="#1D2430" BorderBrush="#4C5D80">
                                            <TextBlock Text="{Binding InvoiceMatchSummary}" FontSize="11" Foreground="#D9E6FF"/>
                                        </Border>
                                        <Border Style="{StaticResource ChipBorder}" Background="#1D2430" BorderBrush="#4C5D80">
                                            <TextBlock Text="{Binding LookbackScopeSummary}" FontSize="11" Foreground="#D9E6FF"/>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>

                                <Border Grid.Column="1" Margin="20,0,0,0" Background="#1B2230" BorderBrush="#34518A" BorderThickness="1" CornerRadius="14" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="Rechnungen anzeigen" FontSize="11" FontWeight="SemiBold" Foreground="#BED1F4"/>
                                        <TextBlock Text="Vorschau zeigt Mail- und Trefferdaten. 'Anhang oeffnen' klappt nur, wenn die Datei bereits heruntergeladen wurde." Margin="0,10,0,0" FontSize="11" Foreground="#D6DEEF" TextWrapping="Wrap"/>
                                        <Button Content="Scanner" Style="{StaticResource ToolButton}" Margin="0,14,0,0" HorizontalAlignment="Left" Click="OnScannerNavClicked"/>
                                        <TextBlock Text="Die zwei kleinen dunklen Balken waren vorher interne Tabs fuer Liste/Vorschau. Die habe ich jetzt entfernt." Margin="0,10,0,0" FontSize="10.5" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" Margin="0,12,0,0" Style="{StaticResource RevealGrid}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.4*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="0.9*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Row="0" Grid.ColumnSpan="3" Style="{StaticResource SurfaceCard}" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="360"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <WrapPanel Margin="0,0,0,12">
                                            <Button x:Name="InvoiceResultsButton" Content="Rechnungen" Style="{StaticResource ToolPrimaryButton}" Margin="0,0,8,0" Click="OnShowInvoicesClicked"/>
                                            <Button x:Name="DownloadedResultsButton" Content="Downloads" Style="{StaticResource ToolButton}" Margin="0,0,8,0" Click="OnShowDownloadedClicked"/>
                                            <Button x:Name="AllResultsButton" Content="Alle" Style="{StaticResource ToolButton}" Margin="0,0,16,0" Click="OnShowAllResultsClicked"/>
                                            <Button x:Name="ViewButton" Content="Vorschau" Style="{StaticResource ToolButton}" Margin="0,0,8,0" Click="OnViewClicked" IsEnabled="{Binding CanPreviewSelection}"/>
                                            <Button x:Name="OpenFileButton" Content="Datei oeffnen" Style="{StaticResource ToolButton}" Margin="0,0,8,0" Click="OnOpenSelectedFileClicked" IsEnabled="{Binding CanOpenSelectedFile}"/>
                                            <Button x:Name="DownloadButton" Content="Herunterladen" Style="{StaticResource ToolPrimaryButton}" Margin="0,0,8,0" Click="OnDownloadSelectionClicked" IsEnabled="{Binding CanDownloadSelection}"/>
                                            <Button x:Name="DeleteButton" Content="Loeschen" Style="{StaticResource ToolDangerButton}" Margin="0,0,16,0" Click="OnDeleteClicked" IsEnabled="{Binding CanDeleteSelection}"/>
                                            <CheckBox x:Name="OnlyAttachmentsCheckBox" Content="Nur mit Anhang" Style="{StaticResource InputCheckBox}" IsChecked="{Binding OnlyWithAttachments}" Margin="0,8,16,0"/>
                                            <CheckBox x:Name="OnlyDocPdfCheckBox" Content="Nur PDF / DOC" Style="{StaticResource InputCheckBox}" IsChecked="{Binding OnlyDocPdf}" Margin="0,8,0,0"/>
                                        </WrapPanel>

                                        <WrapPanel>
                                            <Border Style="{StaticResource ChipBorder}"><TextBlock Text="{Binding LookbackScopeSummary}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/></Border>
                                            <Border Style="{StaticResource ChipBorder}"><TextBlock Text="{Binding OldestMailSummary}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/></Border>
                                            <Border Style="{StaticResource ChipBorder}"><TextBlock Text="{Binding ExcludedFoldersSummary}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/></Border>
                                        </WrapPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="20,0,0,0">
                                        <TextBlock Text="Suche" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="SearchBox" Grid.Column="0" Style="{StaticResource SearchTextBoxStyle}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Suche nach Konto, Betreff, Absender oder Dateiname"/>
                                            <Border Grid.Column="1" Width="36" Margin="8,0,0,0" Background="#1C2028" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8">
                                                <Viewbox Margin="10,9"><Grid Width="12" Height="12"><Ellipse Width="7" Height="7" Stroke="{StaticResource MutedBrush}" StrokeThickness="1.5" HorizontalAlignment="Left" VerticalAlignment="Top"/><Path Data="M 7 7 L 11 11" Stroke="{StaticResource MutedBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/></Grid></Viewbox>
                                            </Border>
                                        </Grid>
                                        <TextBlock x:Name="SelectionInfoText" Text="{Binding SelectionInfo}" Margin="0,10,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource SurfaceCard}" Padding="0">
                                <DataGrid x:Name="CandidatesGrid"
                                          ItemsSource="{Binding Candidates}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          SelectionMode="Extended"
                                          SelectionChanged="OnCandidatesSelectionChanged"
                                          MouseDoubleClick="OnCandidatesMouseDoubleClick"
                                          Background="Transparent"
                                          HeadersVisibility="Column"
                                          RowBackground="Transparent"
                                          AlternatingRowBackground="#20242C"
                                          GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="0.95*" Header="Konto" Binding="{Binding AccountName}"/>
                                        <DataGridTextColumn Width="1.15*" Header="Absender" Binding="{Binding Sender}"/>
                                        <DataGridTextColumn Width="2.1*" Header="Betreff" Binding="{Binding Subject}"/>
                                        <DataGridTextColumn Width="0.95*" Header="Empfangen" Binding="{Binding ReceivedAtDisplay}"/>
                                        <DataGridTextColumn Width="1.15*" Header="Anhang" Binding="{Binding AttachmentName}"/>
                                        <DataGridTextColumn Width="1.3*" Header="Warum gefunden" Binding="{Binding MatchReason}"/>
                                        <DataGridTextColumn Width="98" Header="Datei" Binding="{Binding FileAvailabilityLabel}"/>
                                        <DataGridTextColumn Width="68" Header="Score" Binding="{Binding PriorityScore}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>

                            <Grid Grid.Row="1" Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="{StaticResource HeroBrush}" BorderBrush="#334152" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="170"/></Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="AKTUELLE VORSCHAU" FontSize="10" FontWeight="SemiBold" Foreground="#A9C2F3"/>
                                            <TextBlock Text="{Binding PreviewSubject}" Margin="0,8,0,0" FontSize="22" FontWeight="SemiBold" Foreground="White" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding PreviewSender}" Margin="0,8,0,0" FontSize="12" Foreground="#D6DEEF" TextWrapping="Wrap"/>
                                            <WrapPanel Margin="0,12,0,0">
                                                <Border Style="{StaticResource ChipBorder}" Background="#18202B" BorderBrush="#42577D"><TextBlock Text="{Binding PreviewAccountName}" FontSize="11" Foreground="#D9E6FF"/></Border>
                                                <Border Style="{StaticResource ChipBorder}" Background="#18202B" BorderBrush="#42577D"><TextBlock Text="{Binding PreviewReceivedAtDisplay}" FontSize="11" Foreground="#D9E6FF"/></Border>
                                            </WrapPanel>
                                        </StackPanel>
                                        <Border Grid.Column="1" Margin="16,0,0,0" Background="#1B2230" BorderBrush="#34518A" BorderThickness="1" CornerRadius="14" Padding="12">
                                            <StackPanel>
                                                <TextBlock Text="Dateistatus" FontSize="11" FontWeight="SemiBold" Foreground="#BED1F4"/>
                                                <TextBlock Text="{Binding PreviewAttachmentName}" Margin="0,10,0,0" FontSize="13" FontWeight="SemiBold" Foreground="White" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding PreviewCategoryLabel}" Margin="0,6,0,0" FontSize="11" Foreground="#D6DEEF" TextWrapping="Wrap"/>
                                                <WrapPanel Margin="0,12,0,0">
                                                    <Button Content="Datei oeffnen" Style="{StaticResource ToolPrimaryButton}" Margin="0,0,8,0" Click="OnOpenPreviewAttachmentClicked"/>
                                                    <Button Content="Herunterladen" Style="{StaticResource ToolButton}" Click="OnDownloadSelectionClicked" IsEnabled="{Binding CanDownloadSelection}"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="1" Style="{StaticResource SurfaceCard}" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Trefferdetails" Style="{StaticResource SectionTitle}" Margin="0"/>
                                            <TextBlock Text="{Binding PreviewMatchReason}" Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Style="{StaticResource ChipBorder}" Background="#151A22" BorderBrush="#303744" Margin="12,0,0,0">
                                            <TextBlock Text="Doppelklick = Vorschau + Datei oeffnen" FontSize="10.5" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2" Style="{StaticResource SurfaceCard}" Padding="0">
                                    <Grid>
                                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                        <Border Grid.Row="0" Background="#1A1E25" BorderBrush="#2F3642" BorderThickness="0,0,0,1" CornerRadius="12,12,0,0" Padding="16,12">
                                            <StackPanel>
                                                <TextBlock Text="Mail-Inhalt" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="Wenn noch keine lokale Datei vorliegt, siehst du hier trotzdem schon den Kontext zum Treffer." Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                        <TextBox Grid.Row="1" Text="{Binding PreviewContentText}" IsReadOnly="True" BorderThickness="0" Background="{StaticResource CodeBackgroundBrush}" Foreground="{StaticResource TextPrimaryBrush}" Padding="18" FontFamily="Consolas" FontSize="11.2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>

                    <ScrollViewer x:Name="AccountsWorkspace" Visibility="{Binding AccountsPageVisibility}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="0,0,4,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="{StaticResource HeroBrush}" BorderBrush="#334152" BorderThickness="1" CornerRadius="16" Padding="22" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="300"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="ACCOUNT WORKSPACE" FontSize="10" FontWeight="SemiBold" Foreground="#9DB6E6"/>
                                    <TextBlock Text="Konten und Speicherorte" Margin="0,8,0,0" FontSize="28" FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock Text="Konten verwalten, testen und direkt im Hauptfenster speichern." Margin="0,8,0,0" FontSize="13" Foreground="#D4DCEE" TextWrapping="Wrap"/>
                                    <WrapPanel Margin="0,10,0,0">
                                        <Border Style="{StaticResource ChipBorder}" Background="#1D2430" BorderBrush="#4C5D80">
                                            <TextBlock Text="{Binding AccountCountSummary}" FontSize="11" Foreground="#D9E6FF"/>
                                        </Border>
                                        <Border Style="{StaticResource ChipBorder}" Background="#1D2430" BorderBrush="#4C5D80">
                                            <TextBlock Text="{Binding SettingsStorageSummary}" FontSize="11" Foreground="#D9E6FF"/>
                                        </Border>
                                    </WrapPanel>
                                    <TextBlock Text="{Binding SettingsProviderSummary}" Margin="0,10,0,0" FontSize="10.5" Foreground="#D6DEEF" TextWrapping="Wrap"/>
                                </StackPanel>

                                <Border Grid.Column="1" Margin="20,0,0,0" Background="#1B2230" BorderBrush="#34518A" BorderThickness="1" CornerRadius="14" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="Hinweis" FontSize="11" FontWeight="SemiBold" Foreground="#BED1F4"/>
                                        <TextBlock Text="Fuer Gmail wird in der Regel ein App-Passwort benoetigt, wenn 2-Faktor-Authentifizierung aktiv ist." Margin="0,10,0,0" FontSize="11" Foreground="#D6DEEF" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="0" Style="{StaticResource SurfaceCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Konto-Explorer" Style="{StaticResource SectionTitle}" Margin="0"/>
                                    <TextBlock Text="Bestehende Eintraege waehlen oder neue Konten vorbereiten" Margin="0,6,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                </StackPanel>

                                <ListBox x:Name="EmbeddedAccountsListBox"
                                 Grid.Row="1"
                                         ItemsSource="{Binding EditorAccounts}"
                                         SelectedItem="{Binding SelectedEditorAccount}"
                                         SelectionChanged="OnEmbeddedAccountSelectionChanged"
                                         BorderThickness="0"
                                         Background="Transparent">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="30" Height="30" Background="#20263A" BorderBrush="#4B69A4" BorderThickness="1" CornerRadius="8" VerticalAlignment="Top">
                                                    <TextBlock Text="@" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#C5D8FF" FontWeight="SemiBold"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding EmailAddress}" Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding ImapHost}" Margin="0,6,0,0" FontSize="10" Foreground="{StaticResource MutedBrush}"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="10"/>
                                            <Setter Property="Margin" Value="0,0,0,10"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="ItemBorder" Background="#1D2028" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="3"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Border x:Name="SelectionIndicator" Width="3" Margin="0,2,10,2" CornerRadius="2" Background="{StaticResource AccentBrush}" Opacity="0"/>
                                                                <ContentPresenter Grid.Column="1"/>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource BorderBrushStrong}"/>
                                                                <Setter TargetName="ItemBorder" Property="Background" Value="#232833"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource SelectionBrush}"/>
                                                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                                <Setter TargetName="SelectionIndicator" Property="Opacity" Value="1"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="+" Style="{StaticResource ToolbarIconButton}" ToolTip="Neues Konto" Click="OnEmbeddedAddAccountClicked"/>
                                    <Button Grid.Column="1" Content="-" Style="{StaticResource ToolbarIconButton}" Margin="8,0,0,0" ToolTip="Konto loeschen" Click="OnEmbeddedRemoveAccountClicked"/>
                                    <TextBlock Grid.Column="2" Text="Ausgewaehltes Konto bearbeiten" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Row="0" Grid.ColumnSpan="3" Style="{StaticResource SurfaceCard}" Margin="0,0,0,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding StatusMessage}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding SelectedEditorAccountSummary}" Margin="0,8,0,0" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Debug" Style="{StaticResource ToolButton}" Width="92" HorizontalAlignment="Right" Click="OnOpenDebugClicked"/>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource SurfaceCard}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Konto" Style="{StaticResource SectionTitle}" Margin="0,0,0,12"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Anzeigename" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource InputTextBox}" Text="{Binding SelectedEditorAccount.DisplayName, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,12,0,0" Text="E-Mail" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource InputTextBox}" Text="{Binding SelectedEditorAccount.EmailAddress, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,12,0,0" Text="Benutzername" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource InputTextBox}" Text="{Binding SelectedEditorAccount.UserName, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,12,0,0" Text="Passwort" Style="{StaticResource FieldLabel}"/>
                                    <PasswordBox x:Name="EmbeddedPasswordBox" Grid.Row="4" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource InputPasswordBox}" PasswordChanged="OnEmbeddedPasswordChanged"/>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource SurfaceCard}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="IMAP-Einstellungen" Style="{StaticResource SectionTitle}" Margin="0,0,0,12"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Server" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource InputTextBox}" Text="{Binding SelectedEditorAccount.ImapHost, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,12,0,0" Text="Port" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" Width="140" HorizontalAlignment="Left" Style="{StaticResource InputTextBox}" Text="{Binding SelectedEditorAccount.ImapPort}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,12,0,0" Text="Ordner" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" Margin="0,12,0,0" Style="{StaticResource InputTextBox}" Text="{Binding SelectedEditorAccount.FolderName, UpdateSourceTrigger=PropertyChanged}"/>
                                    <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Margin="0,14,0,0">
                                        <CheckBox Content="SSL verwenden" Style="{StaticResource InputCheckBox}" IsChecked="{Binding SelectedEditorAccount.UseSsl}"/>
                                        <Border Style="{StaticResource InsetCard}" Margin="0,12,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Best Practice" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="Fuer produktive Postfaecher empfehlen sich IMAP ueber 993, SSL und ein dedizierter Zielordner wie INBOX." Margin="0,8,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="2" Grid.Column="2" Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource SurfaceCard}">
                                <StackPanel>
                                    <TextBlock Text="Globale Einstellungen" Style="{StaticResource SectionTitle}"/>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Lookback" Style="{StaticResource FieldLabel}" Margin="0,9,0,0"/>
                                        <TextBox Grid.Column="1" Width="104" Style="{StaticResource InputTextBox}" Text="{Binding EditorInitialLookbackDays}"/>
                                        <TextBlock Grid.Column="2" Text="Tage" Margin="12,9,0,0" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </Grid>
                                    <TextBlock Text="Ausgeschlossene Ordner / Muster" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding EditorExcludedFolderPatternsText, UpdateSourceTrigger=PropertyChanged}" Height="156" Style="{StaticResource InputTextBox}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
                                    <TextBlock Text="Jede Zeile entspricht einem Muster oder Ordner, der beim Scan uebersprungen wird." Margin="0,10,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource SurfaceCard}">
                                <StackPanel>
                                    <TextBlock Text="Speicherorte" Style="{StaticResource SectionTitle}"/>
                                    <TextBlock Text="Datenbank" Style="{StaticResource FieldLabel}"/>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Style="{StaticResource InputTextBox}" Text="{Binding EditorDatabasePath}" IsReadOnly="True"/>
                                        <Button Grid.Column="1" Content="..." Style="{StaticResource ToolbarIconButton}" Margin="8,0,0,0" Click="OnEmbeddedBrowseDatabaseClicked"/>
                                    </Grid>
                                    <TextBlock Text="Dokumentenordner" Style="{StaticResource FieldLabel}"/>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Style="{StaticResource InputTextBox}" Text="{Binding EditorDocumentRootPath}" IsReadOnly="True"/>
                                        <Button Grid.Column="1" Content="..." Style="{StaticResource ToolbarIconButton}" Margin="8,0,0,0" Click="OnEmbeddedBrowseDocumentClicked"/>
                                    </Grid>
                                    <Border Style="{StaticResource InsetCard}">
                                        <StackPanel>
                                            <TextBlock Text="Tipp" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="Verwende kurze, stabile Speicherpfade, damit Downloads und Vorschauen zuverlaessig funktionieren." Margin="0,8,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="3" Grid.Column="2" Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource SurfaceCard}">
                                <StackPanel>
                                    <TextBlock Text="Dateitypen" Style="{StaticResource SectionTitle}"/>
                                    <WrapPanel>
                                        <CheckBox Content="PDF" Style="{StaticResource InputCheckBox}" IsChecked="{Binding SelectedEditorAccount.SearchPdf}" Margin="0,0,14,10"/>
                                        <CheckBox Content="DOC" Style="{StaticResource InputCheckBox}" IsChecked="{Binding SelectedEditorAccount.SearchDoc}" Margin="0,0,14,10"/>
                                        <CheckBox Content="DOCX" Style="{StaticResource InputCheckBox}" IsChecked="{Binding SelectedEditorAccount.SearchDocx}" Margin="0,0,14,10"/>
                                        <CheckBox Content="XLS" Style="{StaticResource InputCheckBox}" IsChecked="{Binding SelectedEditorAccount.SearchXls}" Margin="0,0,14,10"/>
                                        <CheckBox Content="XLSX" Style="{StaticResource InputCheckBox}" IsChecked="{Binding SelectedEditorAccount.SearchXlsx}" Margin="0,0,14,10"/>
                                        <CheckBox Content="PPT" Style="{StaticResource InputCheckBox}" IsChecked="{Binding SelectedEditorAccount.SearchPpt}" Margin="0,0,14,10"/>
                                        <CheckBox Content="PPTX" Style="{StaticResource InputCheckBox}" IsChecked="{Binding SelectedEditorAccount.SearchPptx}" Margin="0,0,14,10"/>
                                        <CheckBox Content="Bilder" Style="{StaticResource InputCheckBox}" IsChecked="{Binding SelectedEditorAccount.SearchImages}" Margin="0,0,14,10"/>
                                        <CheckBox Content="TXT" Style="{StaticResource InputCheckBox}" IsChecked="{Binding SelectedEditorAccount.SearchTxt}" Margin="0,0,14,10"/>
                                        <CheckBox Content="Sonstige" Style="{StaticResource InputCheckBox}" IsChecked="{Binding SelectedEditorAccount.SearchOther}" Margin="0,0,14,10"/>
                                    </WrapPanel>
                                    <TextBlock Text="Nur aktivierte Dateitypen werden beim Scan als Kandidaten uebernommen." Margin="0,10,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource SurfaceCard}">
                                <StackPanel>
                                    <TextBlock Text="Ignorierte Dateinamen" Style="{StaticResource SectionTitle}"/>
                                    <TextBlock Text="Muster pro Zeile, z.B. logo, impressum, agb, footer" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding SelectedEditorAccount.IgnoredAttachmentNamePatternsText, UpdateSourceTrigger=PropertyChanged}"
                                             Height="120"
                                             Style="{StaticResource InputTextBox}"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             TextWrapping="Wrap"/>
                                    <TextBlock Text="Wenn ein Dateiname eines dieser Muster enthaelt, wird der Anhang beim Import uebersprungen." Margin="0,10,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="4" Grid.ColumnSpan="3" Style="{StaticResource SurfaceCard}" Padding="16,12" Margin="0,14,0,0" VerticalAlignment="Bottom">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Aenderungen zuerst testen, danach speichern." FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="Die Einstellungen werden direkt in deinen lokalen App-Daten abgelegt." Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="Scanner" Style="{StaticResource ToolButton}" Margin="0,0,10,0" Click="OnScannerNavClicked"/>
                                    <Button Content="Dieses Konto testen" Style="{StaticResource ToolButton}" Margin="0,0,10,0" Click="OnEmbeddedTestSelectedClicked" IsEnabled="{Binding CanSaveAccountSettings}"/>
                                    <Button Content="Alle testen" Style="{StaticResource ToolButton}" Margin="0,0,10,0" Click="OnEmbeddedTestAllClicked" IsEnabled="{Binding CanSaveAccountSettings}"/>
                                    <Button Content="Speichern" Style="{StaticResource ToolPrimaryButton}" Click="OnEmbeddedSaveClicked" IsEnabled="{Binding CanSaveAccountSettings}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                    </ScrollViewer>

                    <Grid x:Name="UpdateWorkspace" Visibility="{Binding UpdatePageVisibility}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{StaticResource HeroBrush}" BorderBrush="#334152" BorderThickness="1" CornerRadius="16" Padding="22" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="280"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="UPDATE WORKFLOW" FontSize="10" FontWeight="SemiBold" Foreground="#A9C2F3"/>
                                    <TextBlock Text="Release und Installer" Margin="0,8,0,0" FontSize="30" FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock Text="{Binding UpdatePanelVersionSummary}" Margin="0,10,0,0" FontSize="14" FontWeight="SemiBold" Foreground="#D9E6FF"/>
                                    <TextBlock Text="{Binding UpdatePanelInstallerSummary}" Margin="0,8,0,0" FontSize="12" Foreground="#D6DEEF" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Border Grid.Column="1" Margin="24,0,0,0" Background="#1B2230" BorderBrush="#34518A" BorderThickness="1" CornerRadius="14" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="Release" FontSize="11" FontWeight="SemiBold" Foreground="#BED1F4"/>
                                        <TextBlock Text="{Binding UpdatePanelReleaseTitle}" Margin="0,10,0,0" FontSize="16" FontWeight="SemiBold" Foreground="White" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding UpdatePanelStatusMessage}" Margin="0,8,0,0" FontSize="11" Foreground="#D6DEEF" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="250"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <Border Style="{StaticResource SurfaceCard}" Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Ablauf" Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>
                                        <Border Style="{StaticResource InsetCard}" Margin="0,0,0,10"><TextBlock Text="1. Release-Seite pruefen" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/></Border>
                                        <Border Style="{StaticResource InsetCard}" Margin="0,0,0,10"><TextBlock Text="2. Installer herunterladen" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/></Border>
                                        <Border Style="{StaticResource InsetCard}"><TextBlock Text="3. Setup starten und Dateien ersetzen" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/></Border>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SurfaceCard}">
                                    <StackPanel>
                                        <TextBlock Text="Hinweis" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                        <TextBlock Text="Der Update-Check laeuft beim Start automatisch gegen GitHub Releases. Installer-Downloads koennen direkt hier ausgelost werden." FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <Border Grid.Column="2" Style="{StaticResource SurfaceCard}" Padding="0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#1A1E25" BorderBrush="#2F3642" BorderThickness="0,0,0,1" CornerRadius="12,12,0,0" Padding="16,12">
                                        <StackPanel>
                                            <TextBlock Text="Release-Notizen" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding UpdatePanelReleaseTitle}" Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="1" Style="{StaticResource InsetCard}" CornerRadius="0,0,12,12" Padding="0">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <TextBlock Text="{Binding UpdatePanelReleaseNotes}" Padding="18" FontFamily="Consolas" FontSize="11.5" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" LineHeight="20"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <Border Grid.Row="2" Style="{StaticResource SurfaceCard}" Padding="16,12" Margin="0,14,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding UpdatePanelStatusMessage}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Width="124" Content="Release-Seite" Style="{StaticResource ToolButton}" Margin="0,0,10,0" Click="OnOpenReleasePageClicked"/>
                                    <Button Width="132" Content="Update laden" Style="{StaticResource ToolPrimaryButton}" Margin="0,0,10,0" Click="OnInstallUpdateClicked" IsEnabled="{Binding CanInstallUpdate}"/>
                                    <Button Width="86" Content="Scanner" Style="{StaticResource ToolButton}" Click="OnScannerNavClicked"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid x:Name="DebugWorkspace" Visibility="{Binding DebugPageVisibility}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{StaticResource HeroBrush}" BorderBrush="#334152" BorderThickness="1" CornerRadius="16" Padding="22" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="290"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="DIAGNOSTIC WORKSPACE" Style="{StaticResource SmallCaption}" Foreground="#A9C2F3"/>
                                    <TextBlock Text="Debug Output" Margin="0,8,0,0" FontSize="30" FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock Text="Registry, Settings und Fehler ohne weiteres Fenster pruefen." Margin="0,8,0,0" FontSize="13" Foreground="#D6DEEF" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Border Grid.Column="1" Margin="24,0,0,0" Background="#1B2230" BorderBrush="#34518A" BorderThickness="1" CornerRadius="14" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="Live-Status" FontSize="11" FontWeight="SemiBold" Foreground="#BED1F4"/>
                                        <TextBlock Text="{Binding DebugLog.StatusText}" Margin="0,10,0,0" FontSize="11" Foreground="#D6DEEF" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding DebugLog.TimestampText}" Margin="0,8,0,0" FontSize="11" Foreground="#D6DEEF" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource SurfaceCard}" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Werkzeuge" Style="{StaticResource SectionTitle}" Margin="0"/>
                                    <TextBlock Text="Debug zeigt technische Rohdaten: Registry = gespeicherte Konfiguration, Settings = geladene App-Einstellungen, Fehler = Ausnahmen." Margin="0,6,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Content="Kopieren" Style="{StaticResource ToolButton}" Margin="0,0,8,0" Click="OnCopyDebugClicked"/>
                                    <Button Content="Leeren" Style="{StaticResource ToolDangerButton}" Click="OnClearDebugClicked"/>
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource SurfaceCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource InsetCard}" Padding="0">
                                    <Grid>
                                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                        <TextBlock Text="Registry" Margin="16,14,16,0" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBox Grid.Row="1" Text="{Binding DebugLog.RegistryText, Mode=OneWay}" IsReadOnly="True" Background="{StaticResource CodeBackgroundBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0" Padding="16" FontFamily="Consolas" FontSize="10.5" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource InsetCard}" Padding="0">
                                    <Grid>
                                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                        <TextBlock Text="Geladene Settings" Margin="16,14,16,0" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBox Grid.Row="1" Text="{Binding DebugLog.SettingsText, Mode=OneWay}" IsReadOnly="True" Background="{StaticResource CodeBackgroundBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0" Padding="16" FontFamily="Consolas" FontSize="10.5" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource InsetCard}" Padding="0">
                                    <Grid>
                                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                        <TextBlock Text="Allgemein" Margin="16,14,16,0" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBox Grid.Row="1" Text="{Binding DebugLog.GeneralText, Mode=OneWay}" IsReadOnly="True" Background="{StaticResource CodeBackgroundBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0" Padding="16" FontFamily="Consolas" FontSize="10.5" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource InsetCard}" Padding="0" BorderBrush="#6C3E46">
                                    <Grid>
                                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                        <TextBlock Text="Fehler" Margin="16,14,16,0" FontSize="12" FontWeight="SemiBold" Foreground="#FFD7DA"/>
                                        <TextBox Grid.Row="1" Text="{Binding DebugLog.ErrorText, Mode=OneWay}" IsReadOnly="True" Background="#190F12" Foreground="#FFD7DA" BorderThickness="0" Padding="16" FontFamily="Consolas" FontSize="10.5" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3" Style="{StaticResource SurfaceCard}" Padding="16,12" Margin="0,14,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding DebugLog.StatusText}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding DebugLog.TimestampText}" FontSize="11" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
