<Window x:Class="MailScanner.App.MailPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Mail-Vorschau"
        Width="1160"
        Height="840"
        MinWidth="940"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource AppBackgroundBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Margin="12"
            Background="{StaticResource ChromeBrush}"
            BorderBrush="{StaticResource BorderBrushStrong}"
            BorderThickness="1"
            CornerRadius="18"
            Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource TitleBarBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="18,18,0,0">
                <Grid MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                        <Border Style="{StaticResource HeaderIconTile}">
                            <Grid Margin="5">
                                <Path Data="M 2 4 L 12 4 L 12 11 L 2 11 Z M 2 4 L 7 8 L 12 4"
                                      Stroke="#C5D8FF"
                                      StrokeThickness="1.25"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Stretch="Fill"/>
                            </Grid>
                        </Border>
                        <TextBlock Text="Mail Preview" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Margin="18,0,18,0"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="{StaticResource MutedBrush}"
                               Text="Metadaten, Treffergrund und der aktuell verfuegbare Mail-Inhalt auf einen Blick."
                               TextTrimming="CharacterEllipsis"/>

                    <Border Grid.Column="2" Style="{StaticResource TitlePill}" Margin="0,0,10,0" VerticalAlignment="Center" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="Mail Preview" FontSize="11" FontWeight="SemiBold" Foreground="#D9E6FF"/>
                    </Border>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource WindowControlButton}" Click="OnMinimizeWindowClicked" Content="-"/>
                        <Button Style="{StaticResource WindowControlButton}" Click="OnToggleMaximizeWindowClicked" Content="[]"/>
                        <Button Style="{StaticResource WindowControlButton}" Click="OnCloseClicked" Content="X"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource HeroBrush}" BorderBrush="#334152" BorderThickness="1" CornerRadius="16" Padding="22" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="320"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="TREFFER VORSCHAU" Style="{StaticResource SmallCaption}" Foreground="#A9C2F3"/>
                            <TextBlock Text="{Binding Subject}" Margin="0,8,0,0" FontSize="28" FontWeight="SemiBold" Foreground="White" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Sender}" Margin="0,8,0,0" FontSize="13" Foreground="#D6DEEF" TextWrapping="Wrap"/>
                            <WrapPanel Margin="0,14,0,0">
                                <Border Style="{StaticResource ChipBorder}" Background="#18202B" BorderBrush="#42577D">
                                    <TextBlock Text="{Binding AccountName}" FontSize="11" Foreground="#D9E6FF"/>
                                </Border>
                                <Border Style="{StaticResource ChipBorder}" Background="#18202B" BorderBrush="#42577D">
                                    <TextBlock Text="{Binding FolderName}" FontSize="11" Foreground="#D9E6FF"/>
                                </Border>
                                <Border Style="{StaticResource ChipBorder}" Background="#18202B" BorderBrush="#42577D">
                                    <TextBlock Text="{Binding ReceivedAtDisplay}" FontSize="11" Foreground="#D9E6FF"/>
                                </Border>
                                <Border Style="{StaticResource ChipBorder}" Background="#18202B" BorderBrush="#42577D">
                                    <TextBlock Text="{Binding StatusLabel}" FontSize="11" Foreground="#D9E6FF"/>
                                </Border>
                            </WrapPanel>
                        </StackPanel>

                        <Border Grid.Column="1" Margin="24,0,0,0" Background="#1B2230" BorderBrush="#34518A" BorderThickness="1" CornerRadius="14" Padding="14">
                            <StackPanel>
                                <TextBlock Text="Anhang" FontSize="11" FontWeight="SemiBold" Foreground="#BED1F4"/>
                                <TextBlock Text="{Binding AttachmentName}" Margin="0,10,0,0" FontSize="16" FontWeight="SemiBold" Foreground="White" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding CategoryLabel}" Margin="0,8,0,0" FontSize="11" Foreground="#D6DEEF" TextWrapping="Wrap"/>
                                <Button x:Name="OpenAttachmentButton" Content="Anhang oeffnen" Style="{StaticResource ToolPrimaryButton}" Margin="0,14,0,0" HorizontalAlignment="Left" Click="OnOpenAttachmentClicked"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource SurfaceCard}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#1A1E25" BorderBrush="#2F3642" BorderThickness="0,0,0,1" CornerRadius="12,12,0,0" Padding="16,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Mail-Inhalt" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="Derzeit verfuegbare Metadaten und vorbereiteter Inhalt" Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Style="{StaticResource ChipBorder}" Margin="12,0,0,0" Background="#151A22" BorderBrush="#303744">
                                        <TextBlock Text="Readonly" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <TextBox x:Name="MailContentText"
                                     Grid.Row="1"
                                     Text="Lade Mail-Inhalt..."
                                     IsReadOnly="True"
                                     BorderThickness="0"
                                     Background="{StaticResource CodeBackgroundBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     Padding="18"
                                     FontFamily="Consolas"
                                     FontSize="11.5"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="2">
                        <Border Style="{StaticResource SurfaceCard}" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Warum gefunden" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding MatchReason}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SurfaceCard}" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Kontext" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Konto" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding AccountName}" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Ordner" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding FolderName}" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Empfangen" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ReceivedAtDisplay}" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource InsetCard}">
                            <StackPanel>
                                <TextBlock Text="Hinweis" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                <TextBlock Text="Der vollstaendige Mail-Body kann spaeter direkt aus dem IMAP-Import geladen werden. Aktuell siehst du die lokal verfuegbare Vorschau." FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="2" Style="{StaticResource SurfaceCard}" Padding="16,12" Margin="0,14,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Anhaenge lassen sich direkt oeffnen, sobald sie lokal vorhanden sind." FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="CloseButton" Content="Schliessen" Style="{StaticResource ToolButton}" Margin="0,0,10,0" Click="OnCloseClicked"/>
                            <Button Content="Anhang oeffnen" Style="{StaticResource ToolPrimaryButton}" Click="OnOpenAttachmentClicked"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
