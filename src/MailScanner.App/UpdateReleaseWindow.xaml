<Window x:Class="MailScanner.App.UpdateReleaseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Update verfuegbar"
        Width="920"
        Height="700"
        MinWidth="760"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource AppBackgroundBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Margin="12"
            Background="{StaticResource ChromeBrush}"
            BorderBrush="{StaticResource BorderBrushStrong}"
            BorderThickness="1"
            CornerRadius="18"
            Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource TitleBarBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="18,18,0,0">
                <Grid MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                        <Border Style="{StaticResource HeaderIconTile}">
                            <Grid Margin="5">
                                <Path Data="M 6 1 L 6 8 M 3 5 L 6 8 L 9 5 M 2 11 L 10 11"
                                      Stroke="#C5D8FF"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"/>
                            </Grid>
                        </Border>
                        <TextBlock Text="Update Center" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Margin="18,0,18,0"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="{StaticResource MutedBrush}"
                               Text="Release-Notizen pruefen, Installer laden und das lokale Update vorbereitet starten."
                               TextTrimming="CharacterEllipsis"/>

                    <Border Grid.Column="2" Style="{StaticResource TitlePill}" Margin="0,0,10,0" VerticalAlignment="Center" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="GitHub Release" FontSize="11" FontWeight="SemiBold" Foreground="#D9E6FF"/>
                    </Border>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource WindowControlButton}" Click="OnMinimizeWindowClicked" Content="-"/>
                        <Button Style="{StaticResource WindowControlButton}" Click="OnToggleMaximizeWindowClicked" Content="[]"/>
                        <Button Style="{StaticResource WindowControlButton}" Click="OnCloseClicked" Content="X"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource HeroBrush}" BorderBrush="#334152" BorderThickness="1" CornerRadius="16" Padding="22" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="280"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="UPDATE WORKFLOW" Style="{StaticResource SmallCaption}" Foreground="#A9C2F3"/>
                            <TextBlock Text="Neue Version verfuegbar" Margin="0,8,0,0" FontSize="30" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="{Binding VersionSummary}" Margin="0,10,0,0" FontSize="14" FontWeight="SemiBold" Foreground="#D9E6FF"/>
                            <TextBlock Text="{Binding InstallerSummary}" Margin="0,8,0,0" FontSize="12" Foreground="#D6DEEF" TextWrapping="Wrap"/>
                        </StackPanel>

                        <Border Grid.Column="1" Margin="24,0,0,0" Background="#1B2230" BorderBrush="#34518A" BorderThickness="1" CornerRadius="14" Padding="14">
                            <StackPanel>
                                <TextBlock Text="Release" FontSize="11" FontWeight="SemiBold" Foreground="#BED1F4"/>
                                <TextBlock Text="{Binding ReleaseTitle}" Margin="0,10,0,0" FontSize="16" FontWeight="SemiBold" Foreground="White" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding StatusMessage}" Margin="0,8,0,0" FontSize="11" Foreground="#D6DEEF" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <Border Style="{StaticResource SurfaceCard}" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Ablauf" Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>
                                <Border Style="{StaticResource InsetCard}" Margin="0,0,0,10">
                                    <TextBlock Text="1. Release-Seite pruefen" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </Border>
                                <Border Style="{StaticResource InsetCard}" Margin="0,0,0,10">
                                    <TextBlock Text="2. Installer herunterladen" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </Border>
                                <Border Style="{StaticResource InsetCard}">
                                    <TextBlock Text="3. Setup starten und Dateien ersetzen" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SurfaceCard}">
                            <StackPanel>
                                <TextBlock Text="Hinweis" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                <TextBlock Text="Beim Installieren wird die laufende App geschlossen, damit der Installer Dateien sauber aktualisieren kann." FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Grid.Column="2" Style="{StaticResource SurfaceCard}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#1A1E25" BorderBrush="#2F3642" BorderThickness="0,0,0,1" CornerRadius="12,12,0,0" Padding="16,12">
                                <StackPanel>
                                    <TextBlock Text="Release-Notizen" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding ReleaseTitle}" Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Style="{StaticResource InsetCard}" CornerRadius="0,0,12,12" Padding="0" Margin="0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBlock Text="{Binding ReleaseNotes}"
                                               Padding="18"
                                               FontFamily="Consolas"
                                               FontSize="11.5"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextWrapping="Wrap"
                                               LineHeight="20"/>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="2" Style="{StaticResource SurfaceCard}" Padding="16,12" Margin="0,14,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Width="124" Content="Release-Seite" Style="{StaticResource ToolButton}" Margin="0,0,10,0" Click="OnOpenReleasePageClicked"/>
                            <Button Width="132" Content="Update laden" Style="{StaticResource ToolPrimaryButton}" Margin="0,0,10,0" Click="OnInstallUpdateClicked" IsEnabled="{Binding CanInstallUpdate}"/>
                            <Button Width="86" Content="Spaeter" Style="{StaticResource ToolButton}" Click="OnCloseClicked"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
