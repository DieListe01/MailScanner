<Window x:Class="MailScanner.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MailScanner"
        Height="810"
        Width="1320"
        MinHeight="740"
        MinWidth="1180"
        Background="#EAF2FD">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FBFDFF" />
        <SolidColorBrush x:Key="TextBrush" Color="#15314F" />
        <SolidColorBrush x:Key="MutedBrush" Color="#607A98" />
        <SolidColorBrush x:Key="StrokeBrush" Color="#D4E0EE" />
        <LinearGradientBrush x:Key="ShellBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#F4F8FE" />
            <GradientStop Offset="0.45" Color="#E5EFFB" />
            <GradientStop Offset="1" Color="#D9E7FA" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="HeroBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#14385C" />
            <GradientStop Offset="0.55" Color="#245A92" />
            <GradientStop Offset="1" Color="#173B60" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="InvoiceBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#3F75B4" />
            <GradientStop Offset="1" Color="#2A5C97" />
        </LinearGradientBrush>
        <DropShadowEffect x:Key="PanelShadow" BlurRadius="30" ShadowDepth="12" Color="#2E527A" Opacity="0.14" />
        <DropShadowEffect x:Key="HeroShadow" BlurRadius="40" ShadowDepth="16" Color="#203B59" Opacity="0.16" />
        <DropShadowEffect x:Key="ButtonShadow" BlurRadius="16" ShadowDepth="6" Color="#16385C" Opacity="0.18" />

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="Effect" Value="{StaticResource PanelShadow}" />
        </Style>

        <Style x:Key="HeroChipStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="CornerRadius" Value="11" />
            <Setter Property="Background" Value="#234A75" />
            <Setter Property="BorderBrush" Value="#335E89" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="InfoChipStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Padding" Value="11,7" />
            <Setter Property="CornerRadius" Value="11" />
            <Setter Property="Background" Value="#EEF5FF" />
            <Setter Property="BorderBrush" Value="#D9E7F6" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F6FAFF" />
            <Setter Property="Background" Value="#2A649B" />
            <Setter Property="BorderBrush" Value="#5E8DBA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Effect" Value="{StaticResource ButtonShadow}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonRoot"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <Border Margin="1"
                                        Height="10"
                                        VerticalAlignment="Top"
                                        CornerRadius="9"
                                        Opacity="0.08"
                                        Background="#FFFFFF" />
                                <Border Margin="1"
                                        CornerRadius="9"
                                        BorderBrush="#14FFFFFF"
                                        BorderThickness="1" />
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.97" />
                                <Setter TargetName="ButtonRoot" Property="BorderBrush" Value="#86ADD3" />
                                <Setter TargetName="ButtonRoot" Property="Background" Value="#3170AC" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonRoot" Property="RenderTransformOrigin" Value="0.5,0.5" />
                                <Setter TargetName="ButtonRoot" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="1" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <StaticResource ResourceKey="ShellBrush" />
        </Grid.Background>

        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="28" CornerRadius="30" Background="{StaticResource HeroBrush}" Effect="{StaticResource HeroShadow}">
                <Grid>
                    <Canvas IsHitTestVisible="False">
                        <Ellipse Width="320" Height="320" Fill="#10FFFFFF" Canvas.Left="650" Canvas.Top="-160" />
                        <Ellipse Width="240" Height="240" Fill="#10000000" Canvas.Left="860" Canvas.Top="34" />
                        <Ellipse Width="360" Height="360" Fill="#0F000000" Canvas.Left="-130" Canvas.Top="90" />
                        <Rectangle Width="520" Height="240" RadiusX="120" RadiusY="120" Fill="#0BFFFFFF" Canvas.Left="280" Canvas.Top="-40" />
                    </Canvas>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="360" />
                        </Grid.ColumnDefinitions>

                        <Grid Margin="0,0,28,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <DockPanel LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left"
                                               Text="MailScanner"
                                               FontFamily="Bahnschrift"
                                               FontSize="40"
                                               FontWeight="SemiBold"
                                               Foreground="#F7FBFF" />
                                    <Border DockPanel.Dock="Left"
                                            Margin="12,10,0,0"
                                            Padding="10,5"
                                            CornerRadius="10"
                                            Background="#2A5B90"
                                            BorderBrush="#4B7BAB"
                                            BorderThickness="1">
                                        <TextBlock Text="{Binding CurrentVersionSummary}"
                                                   Foreground="#F4FAFF"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </DockPanel>

                                <TextBlock Margin="0,10,0,0"
                                           MaxWidth="590"
                                           FontSize="16"
                                           LineHeight="27"
                                           TextWrapping="Wrap"
                                           Foreground="#D7E7F9"
                                           Text="Dokumente aus privaten Postfaechern strukturiert sammeln, priorisieren, pruefen und sicher ins lokale DMS uebernehmen." />
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Margin="0,16,170,0"
                                    Padding="14,12"
                                    CornerRadius="14"
                                    Background="#1A456E"
                                    BorderBrush="#35648F"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Release-Status"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#BCD4EE" />
                                    <Border Margin="0,8,0,0"
                                            Padding="10,5"
                                            HorizontalAlignment="Left"
                                            CornerRadius="999"
                                            Background="#24527E"
                                            BorderBrush="#4D7AA6"
                                            BorderThickness="1">
                                        <TextBlock Text="{Binding LatestVersionSummary}"
                                                   Foreground="#F7FBFF"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                    <TextBlock Margin="0,10,0,0"
                                               Text="{Binding UpdateStatusSummary}"
                                               Foreground="#D6E6F8"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <WrapPanel Grid.Row="2" Margin="0,14,0,0">
                                <Border Style="{StaticResource HeroChipStyle}" Background="#224A74">
                                    <TextBlock Text="Vorschau vor dem Download" Foreground="#EFF6FF" />
                                </Border>
                                <Border Style="{StaticResource HeroChipStyle}" Background="#1B4369">
                                    <TextBlock Text="SQLite + Dateisystem" Foreground="#E7F2FF" />
                                </Border>
                                <Border Style="{StaticResource HeroChipStyle}" Background="#315F95">
                                    <TextBlock Text="Kompletter Verlauf scanbar" Foreground="#F6FBFF" />
                                </Border>
                            </WrapPanel>
                        </Grid>

                        <Border Grid.Column="1"
                                Padding="20"
                                CornerRadius="22"
                                Background="#163B61"
                                BorderBrush="#527DA8"
                                BorderThickness="1">
                            <Grid>
                                <Grid.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Offset="0" Color="#183F67" />
                                        <GradientStop Offset="1" Color="#15375A" />
                                    </LinearGradientBrush>
                                </Grid.Background>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Aktionen"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           Foreground="#F5FAFF" />
                                <TextBlock Grid.Row="1"
                                           Margin="0,5,0,0"
                                           Text="Die wichtigsten Aktionen kompakt in einem Bereich."
                                           Foreground="#C2D8F1"
                                           TextWrapping="Wrap" />

                                <Border Grid.Row="2"
                                        Margin="0,14,0,0"
                                        Padding="12"
                                        CornerRadius="16"
                                        Background="#1E4A74"
                                        BorderBrush="#3F6B95"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Button x:Name="SettingsButton" Grid.Row="0" Grid.Column="0" Style="{StaticResource ActionButtonStyle}" Click="OnOpenSettingsClicked" Background="#3974B0" BorderBrush="#75A3CF" Content="Konten" />
                                        <Button x:Name="TestConnectionButton" Grid.Row="0" Grid.Column="2" Style="{StaticResource ActionButtonStyle}" Click="OnTestConnectionsClicked" Background="#2C659A" BorderBrush="#6691BF" Content="Verbindung" />
                                        <Button x:Name="RefreshButton" Grid.Row="2" Grid.Column="0" Style="{StaticResource ActionButtonStyle}" Click="OnRefreshClicked" Background="#275D90" BorderBrush="#5C88B3" Content="Postfaecher pruefen" />
                                        <Button x:Name="DownloadButton" Grid.Row="2" Grid.Column="2" Style="{StaticResource ActionButtonStyle}" Click="OnDownloadSelectionClicked" Background="#487AB0" BorderBrush="#83A8CD" Content="Auswahl speichern" />
                                        <Button Grid.Row="4" Grid.ColumnSpan="3" Style="{StaticResource ActionButtonStyle}" Click="OnOpenLatestReleaseClicked" Background="#638FBF" BorderBrush="#9FBAD8" Content="{Binding LatestReleaseButtonText}" Visibility="{Binding LatestReleaseVisibility}" />
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="3" Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Margin="0,0,8,0"
                                            Padding="10,8"
                                            CornerRadius="12"
                                            Background="#1D456D"
                                            BorderBrush="#366A98"
                                            BorderThickness="1">
                                        <TextBlock Text="Vollscan" Foreground="#D6E6F7" FontWeight="SemiBold" />
                                    </Border>
                                    <Border Grid.Column="1"
                                            Margin="8,0,0,0"
                                            Padding="10,8"
                                            CornerRadius="12"
                                            Background="#1D456D"
                                            BorderBrush="#366A98"
                                            BorderThickness="1">
                                        <TextBlock Text="Live-Updatecheck" Foreground="#D6E6F7" FontWeight="SemiBold" />
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,20,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Margin="0,0,16,0" Style="{StaticResource MetricCardStyle}">
                    <Grid>
                        <Border Height="6" VerticalAlignment="Top" HorizontalAlignment="Stretch" Background="#7FA6D5" CornerRadius="22,22,6,6" />
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Text="Konten" FontSize="12" Foreground="{StaticResource MutedBrush}" />
                            <TextBlock Text="{Binding AccountCountSummary}" Margin="0,6,0,0" FontFamily="Bahnschrift" FontSize="22" Foreground="{StaticResource TextBrush}" />
                            <TextBlock Margin="0,3,0,0" Text="IMAP-Zugaenge zentral verwalten" FontSize="11" Foreground="{StaticResource MutedBrush}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Margin="0,0,16,0" Style="{StaticResource MetricCardStyle}">
                    <Grid>
                        <Border Height="6" VerticalAlignment="Top" HorizontalAlignment="Stretch" Background="#92B5DB" CornerRadius="22,22,6,6" />
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Text="Anhang-Mails" FontSize="12" Foreground="{StaticResource MutedBrush}" />
                            <TextBlock Text="{Binding AttachmentMailSummary}" Margin="0,6,0,0" FontFamily="Bahnschrift" FontSize="22" Foreground="{StaticResource TextBrush}" />
                            <TextBlock Margin="0,3,0,0" Text="Alle Mails mit Anhaengen im Scan" FontSize="11" Foreground="{StaticResource MutedBrush}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Margin="0,0,16,0" Style="{StaticResource MetricCardStyle}">
                    <Grid>
                        <Border Height="6" VerticalAlignment="Top" HorizontalAlignment="Stretch" Background="#7DB5D6" CornerRadius="22,22,6,6" />
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Text="PDF-Kandidaten" FontSize="12" Foreground="{StaticResource MutedBrush}" />
                            <TextBlock Text="{Binding PdfCandidateSummary}" Margin="0,6,0,0" FontFamily="Bahnschrift" FontSize="22" Foreground="{StaticResource TextBrush}" />
                            <TextBlock Margin="0,3,0,0" Text="Nur PDF-Anhaenge landen im Review" FontSize="11" Foreground="{StaticResource MutedBrush}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource MetricCardStyle}" Background="{StaticResource InvoiceBrush}">
                    <Grid>
                        <Border Height="6" VerticalAlignment="Top" HorizontalAlignment="Stretch" Background="#AFCBEB" CornerRadius="22,22,6,6" Opacity="0.65" />
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Text="Rechnungs-Treffer" FontSize="12" Foreground="#D9E8FA" />
                            <TextBlock Text="{Binding InvoiceMatchSummary}" Margin="0,6,0,0" FontFamily="Bahnschrift" FontSize="22" Foreground="#FFFFFF" />
                            <TextBlock Margin="0,3,0,0" Text="Keywords wie invoice, rechnung, beleg" FontSize="11" Foreground="#E8F2FE" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Padding="26" CornerRadius="32" Background="{StaticResource PanelBrush}" Effect="{StaticResource PanelShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="330" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Gefundene Dokumente vor dem Download"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}" />
                            <TextBlock Margin="0,8,0,0"
                                        Text="{Binding StatusMessage}"
                                        Foreground="#4A6785"
                                        TextWrapping="Wrap" />

                            <WrapPanel Margin="0,14,0,0">
                                <Border Style="{StaticResource InfoChipStyle}">
                                    <TextBlock Text="{Binding LookbackScopeSummary}" Foreground="#3D648B" />
                                </Border>
                                <Border Style="{StaticResource InfoChipStyle}">
                                    <TextBlock Text="{Binding OldestMailSummary}" Foreground="#3D648B" />
                                </Border>
                                <Border Style="{StaticResource InfoChipStyle}">
                                    <TextBlock Text="{Binding ExcludedFoldersSummary}" Foreground="#3D648B" />
                                </Border>
                            </WrapPanel>

                            <Border Margin="0,12,0,0"
                                    Padding="16,14"
                                    CornerRadius="18"
                                    Background="#F4F8FE"
                                    BorderBrush="#D7E3F1"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Verbindung und Diagnose"
                                               FontWeight="SemiBold"
                                               Foreground="#35597E" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="Letzte Rueckmeldung aus dem Kontentest"
                                               Foreground="#7A91AA"
                                               FontSize="12" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="{Binding LastConnectionTestSummary}"
                                               Foreground="{StaticResource MutedBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,14,0,0"
                                    Padding="16"
                                    Background="#EAF3FF"
                                    CornerRadius="18"
                                    BorderBrush="#D2E2F5"
                                    BorderThickness="1"
                                    Visibility="{Binding BusyVisibility}">
                                <StackPanel>
                                    <TextBlock Text="{Binding BusyMessage}"
                                               FontWeight="SemiBold"
                                               Foreground="#224F7A" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding ScanProgressSummary}"
                                               Foreground="#4B7195"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding CurrentScanTarget}"
                                               Foreground="#4B7195"
                                               TextWrapping="Wrap" />
                                    <ProgressBar Margin="0,12,0,0"
                                                 Height="10"
                                                 IsIndeterminate="True"
                                                 Foreground="#4A82BD"
                                                 Background="#C8DCF3" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Border Grid.Column="1"
                                HorizontalAlignment="Right"
                                Padding="18"
                                CornerRadius="22"
                                Background="#F3F8FF"
                                BorderBrush="{StaticResource StrokeBrush}"
                                BorderThickness="1">
                            <StackPanel Width="260">
                                <Border Padding="9,4"
                                        HorizontalAlignment="Left"
                                        CornerRadius="999"
                                        Background="#E7F0FC"
                                        BorderBrush="#D2E1F2"
                                        BorderThickness="1">
                                    <TextBlock Text="Suche und Filter"
                                               Foreground="#3A5F84"
                                               FontWeight="SemiBold"
                                               FontSize="12" />
                                </Border>
                                <TextBlock Margin="0,10,0,0"
                                           Text="Filtert Konto, Betreff, Anhang oder Message-ID in der lokalen Review-Liste."
                                           Foreground="#7A90AA"
                                           FontSize="12"
                                           TextWrapping="Wrap" />
                                <TextBox x:Name="SearchBox"
                                          Margin="0,14,0,0"
                                          Height="40"
                                          Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                                <Border Margin="0,12,0,0"
                                        Padding="12,10"
                                        CornerRadius="14"
                                        Background="#FFFFFF"
                                        BorderBrush="#DBE6F3"
                                        BorderThickness="1">
                                    <TextBlock Text="Tipp: Suche nach Absender, Dateiname, Rechnungsbegriffen oder Message-ID."
                                               Foreground="#6E86A0"
                                               FontSize="11"
                                               TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="1"
                            CornerRadius="24"
                            Background="#F6FAFF"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            Padding="10">
                        <DataGrid Grid.Row="1"
                                  x:Name="CandidatesGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  GridLinesVisibility="None"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  SelectionMode="Extended"
                                  SelectionUnit="FullRow"
                                  AlternatingRowBackground="#F2F7FE"
                                  Background="#F8FBFF"
                                  BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ItemsSource="{Binding Candidates}">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#E3EEFB" />
                                    <Setter Property="Foreground" Value="#17304B" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Padding" Value="12,11" />
                                    <Setter Property="BorderBrush" Value="#D5E3F2" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                </Style>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding" Value="9,8" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                </Style>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="#F8FBFF" />
                                    <Setter Property="Foreground" Value="#17304B" />
                                    <Setter Property="Height" Value="44" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#EEF5FF" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#DDECFB" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="1.0*" MinWidth="110" Header="Konto" Binding="{Binding AccountName}" />
                                <DataGridTextColumn Width="1.45*" MinWidth="180" Header="Absender" Binding="{Binding Sender}" />
                                <DataGridTextColumn Width="2.2*" MinWidth="250" Header="Betreff" Binding="{Binding Subject}" />
                                <DataGridTextColumn Width="1.0*" MinWidth="120" Header="Empfangen" Binding="{Binding ReceivedAtDisplay}" />
                                <DataGridTextColumn Width="1.75*" MinWidth="210" Header="Anhang" Binding="{Binding AttachmentName}" />
                                <DataGridTextColumn Width="0.75*" MinWidth="84" Header="Groesse" Binding="{Binding AttachmentSizeDisplay}" />
                                <DataGridTemplateColumn Width="0.7*" MinWidth="90" Header="Score">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,5" CornerRadius="13" Background="{Binding PriorityBadgeBackground}">
                                                <TextBlock HorizontalAlignment="Center" Text="{Binding PriorityScore}" Foreground="{Binding PriorityBadgeForeground}" FontWeight="SemiBold" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="0.92*" MinWidth="110" Header="Prioritaet">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,5" CornerRadius="13" Background="{Binding PriorityBadgeBackground}">
                                                <TextBlock HorizontalAlignment="Center" Text="{Binding PriorityLabel}" Foreground="{Binding PriorityBadgeForeground}" FontWeight="SemiBold" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="1.15*" MinWidth="150" Header="Treffergrund" Binding="{Binding MatchReasonCompact}" />
                                <DataGridTemplateColumn Width="0.9*" MinWidth="110" Header="Kategorie">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,5" CornerRadius="13" Background="{Binding CategoryBadgeBackground}">
                                                <TextBlock HorizontalAlignment="Center" Text="{Binding CategoryLabel}" Foreground="{Binding CategoryBadgeForeground}" FontWeight="SemiBold" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="0.82*" MinWidth="100" Header="Status">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,5" CornerRadius="13" Background="{Binding StatusBadgeBackground}">
                                                <TextBlock HorizontalAlignment="Center" Text="{Binding StatusLabel}" Foreground="{Binding StatusBadgeForeground}" FontWeight="SemiBold" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
