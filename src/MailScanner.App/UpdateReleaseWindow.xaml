<Window x:Class="MailScanner.App.UpdateReleaseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update verfuegbar"
        Height="620"
        Width="760"
        MinHeight="560"
        MinWidth="680"
        WindowStartupLocation="CenterOwner"
        Background="#DDE8F7"
        ResizeMode="NoResize">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="26" CornerRadius="28" Background="#173A61">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Neue Version verfuegbar"
                               FontFamily="Bahnschrift"
                               FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="#F4FAFF" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding VersionSummary}"
                               Foreground="#D9E8FA"
                               FontSize="15" />
                    <TextBlock Margin="0,10,0,0"
                               Text="{Binding InstallerSummary}"
                               Foreground="#BCD4EF"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Column="1" Padding="14,10" CornerRadius="16" Background="#25578E">
                    <TextBlock Text="GitHub Release"
                               Foreground="#F4FAFF"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,18,0,18" Padding="24" CornerRadius="28" Background="#F9FBFF">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Release-Notizen"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#17314E" />
                <TextBlock Grid.Row="1"
                           Margin="0,8,0,0"
                           Text="{Binding ReleaseTitle}"
                           Foreground="#5C7593"
                           FontSize="14" />
                <TextBox Grid.Row="2"
                         Margin="0,16,0,0"
                         Background="#EFF5FD"
                         BorderBrush="#C8D9EE"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding ReleaseNotes}" />
            </Grid>
        </Border>

        <DockPanel Grid.Row="2">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#4E6986" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Width="150" Height="40" Margin="0,0,12,0" Click="OnOpenReleasePageClicked" Background="#5E8FC5" Content="Release-Seite" />
                <Button Width="180" Height="40" Margin="0,0,12,0" Click="OnInstallUpdateClicked" Background="#2E6AAA" Content="Update laden" />
                <Button Width="120" Height="40" Click="OnCloseClicked" Background="#7D96B2" Content="Spaeter" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
